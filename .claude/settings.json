{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm -r build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm exec vitest:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm exec biome:*)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm exec astro:*)",
      "Bash(pnpm exec tsx:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)"
    ],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  }
}
