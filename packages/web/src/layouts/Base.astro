---
interface Props {
  title: string;
  description: string;
  canonical: string;
  jsonLd?: unknown;
  fullBleed?: boolean;
  /** Dev-reference pages (the styleguide) opt out of indexing. */
  noindex?: boolean;
}
const { title, description, canonical, jsonLd, fullBleed = false, noindex = false } = Astro.props;
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Free, non-default faces standing in for the Rosetta direction (no paid licence needed).
        Rosetta names stay first in the --font-* stacks for an optional future drop-in. */}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Spectral:ital,wght@0,300;0,400;1,300;1,400&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="My Second Country" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="generator" content="My Second Country" />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
      )
    }
    {/* Plausible: cookieless, no consent banner needed (FENCE.md). Auto pageviews +
        outbound-link (source citation) clicks + tagged custom events. */}
    <script
      defer
      data-domain="mysecondcountry.com"
      src="https://plausible.io/js/script.outbound-links.tagged-events.js"
      is:inline
    />
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <a class="wordmark" href="/">
          <span class="wordmark-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="6" cy="6" r="4.5" stroke="var(--on-primary)" stroke-width="1.3"/>
              <circle cx="6" cy="6" r="1.8" fill="var(--on-primary)"/>
            </svg>
          </span>
          <span class="wordmark-text">My&nbsp;Second&nbsp;Country</span>
        </a>
        <slot name="nav-extra" />
        <div class="nav-links">
          <a href="/compare/greece-portugal-spain">Compare</a>
          <a href="/screener">Screener</a>
          <a href="/answers">Answers</a>
          <a href="/topics">Topics</a>
          <a href="/tools">Tools</a>
          <a href="/shortlists">Shortlists</a>
        </div>
      </nav>
    </header>
    <main id="main" class={fullBleed ? "bleed" : ""}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>
          My Second Country is run by relocators sharing sourced data, not advisers. Every
          figure links to its source and carries a verified date.
        </p>
        <p class="fineprint">&copy; {year} My Second Country. mysecondcountry.com</p>
      </div>
    </footer>

    <script is:inline>
      // Demand-sensor events. Pageviews and outbound (source) clicks are auto-tracked.
      (function () {
        var p = function (e, o) {
          if (window.plausible) window.plausible(e, o);
        };
        var page = document.querySelector("[data-page]");
        if (page && page.getAttribute("data-page") === "comparison") {
          p("Comparison Viewed", { props: { set: page.getAttribute("data-compare") || "" } });
        }
        var fence = document.querySelector(".fence");
        if (fence && "IntersectionObserver" in window) {
          var seen = false;
          var io = new IntersectionObserver(function (entries) {
            if (!seen && entries.some(function (en) { return en.isIntersecting; })) {
              seen = true;
              p("Fence Seen");
              io.disconnect();
            }
          });
          io.observe(fence);
        }
      })();
    </script>

    <style is:global>
      :root {
        /* Neutrals -- OKLCH, tinted, never pure black/white */
        --paper: oklch(0.9360 0.0149 80.7);            /* #EFE9DF */
        --card: oklch(0.9708 0.0086 84.6);             /* #F8F5EF */
        --panel: oklch(0.9180 0.0140 82);              /* subtle grouping surface */
        --ink: oklch(0.1850 0.0064 56.0);              /* #151210 */
        --muted-foreground: oklch(0.5051 0.0200 84.6); /* #6A6458 -- AA 4.86 on paper */
        --muted-strong: oklch(0.4432 0.0191 73.4);     /* #5A5248 -- prose, 7.06 on card */
        --rule: oklch(0.1850 0.0064 56 / 0.10);        /* hairline */
        --rule-soft: oklch(0.1850 0.0064 56 / 0.07);

        /* Brand teal-navy */
        --primary: oklch(0.3389 0.0625 231.2);         /* #0A3D52 */
        --primary-deep: oklch(0.2834 0.0508 230.4);    /* #072E3E -- hover/active */
        --on-primary: oklch(0.9554 0.0045 214.3);      /* #EDF1F2 -- near-white on teal, 10.2:1 */
        --on-primary-soft: oklch(0.7969 0.0212 224.4); /* #AFC0C7 -- secondary on teal, 6.2:1 */

        /* Country accents -- on light surfaces (text + fills), AA-safe */
        --gr: oklch(0.4846 0.1159 246.4);              /* #15639C -- 5.3:1 on paper */
        --pt: oklch(0.4578 0.1549 18.0);               /* #9B2335 -- 6.5:1 on paper */
        --es: oklch(0.5274 0.1165 57.5);               /* #9C5717 -- 4.6:1 on paper (deepened amber) */
        /* Country accents -- on teal (leader strip, nav pills) */
        --gr-on-primary: oklch(0.7236 0.1138 244.4);   /* #63ADE8 -- 4.8:1 on teal */
        --pt-on-primary: oklch(0.7491 0.1061 11.0);    /* #E8919D -- 5.0:1 on teal */
        --es-on-primary: oklch(0.7767 0.1130 65.2);    /* #E8A765 -- 5.6:1 on teal */

        /* Confidence -- glyph + word, never colour alone; low is neutral, not red */
        --conf-verified: oklch(0.4693 0.1055 152.3);   /* #1F6B3C */
        --conf-good: oklch(0.4840 0.0900 95.9);        /* #6E5E16 */
        --conf-low: oklch(0.4432 0.0191 73.4);         /* #5A5248 */

        /* Fence -- calm sand notice */
        --fence-bg: oklch(0.9391 0.0310 86.5);         /* #F4EAD4 */
        --fence-border: oklch(0.8348 0.0557 86.1);     /* #D9C7A0 */
        --fence-ink: oklch(0.2657 0.0241 77.5);        /* #2C2418 -- 12.8:1 on fence-bg */

        /* Type (Rosetta-first, free stand-ins load now, licensed woff2 is a drop-in swap) */
        --font-display: "Neacademia", "EB Garamond", Georgia, "Times New Roman", serif;
        --font-serif:   "Skolar", "Spectral", Georgia, serif;
        --font-ui:      "Skolar Sans", "IBM Plex Sans", ui-sans-serif, system-ui, sans-serif;
        --font-mono:    "Adapter Mono", "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        --radius: 0.5rem;
        --radius-sm: 0.25rem;
        --measure: 68ch;

        /* Legacy aliases -- keep other pages working with the new palette */
        --paper-2: var(--card);
        --ink-soft: var(--muted-foreground);
        --rule-color: var(--rule);
        --terracotta: var(--primary);
        --terracotta-dark: var(--primary-deep);
        --sea: var(--primary);
        --serif: var(--font-serif);
        --sans: var(--font-ui);
      }

      /* Optional Rosetta upgrade: drop LICENSED woff2 into public/fonts/ and uncomment to
         activate. We ship the free faces above for now; the trial fonts box the letter x
         (and Q/q in Neacademia), so they are intentionally not loaded.
      @font-face { font-family: "Neacademia"; src: url("/fonts/Neacademia-Display.woff2") format("woff2"); font-weight: 400; font-style: normal; font-display: swap; }
      @font-face { font-family: "Neacademia"; src: url("/fonts/Neacademia-Display-Italic.woff2") format("woff2"); font-weight: 400; font-style: italic; font-display: swap; }
      @font-face { font-family: "Skolar"; src: url("/fonts/Skolar.woff2") format("woff2"); font-weight: 300 800; font-style: normal; font-display: swap; }
      @font-face { font-family: "Skolar"; src: url("/fonts/Skolar-Italic.woff2") format("woff2"); font-weight: 300 800; font-style: italic; font-display: swap; }
      @font-face { font-family: "Skolar Sans"; src: url("/fonts/SkolarSans.woff2") format("woff2"); font-weight: 300 800; font-style: normal; font-display: swap; }
      @font-face { font-family: "Skolar Sans"; src: url("/fonts/SkolarSans-Italic.woff2") format("woff2"); font-weight: 300 800; font-style: italic; font-display: swap; }
      */

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
        font-size: 16px;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-ui);
        font-size: 1.0625rem;
        line-height: 1.65;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.6rem 1rem;
        z-index: 10;
      }
      .skip-link:focus {
        left: 0;
      }

      a {
        color: var(--primary-deep);
        text-underline-offset: 2px;
      }
      a:hover {
        color: var(--ink);
      }

      .site-header {
        border-bottom: 1px solid oklch(0.9554 0.0045 214.3 / 0.08);
        background: var(--primary);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .site-nav {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1.25rem;
        height: 52px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      @media (min-width: 640px) {
        .site-nav {
          padding: 0 2rem;
        }
      }
      .wordmark {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
        text-decoration: none;
      }
      .wordmark-icon {
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid oklch(0.9554 0.0045 214.3 / 0.35);
        border-radius: var(--radius-sm);
        flex-shrink: 0;
      }
      .wordmark-text {
        color: var(--on-primary);
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 400;
        letter-spacing: -0.01em;
      }
      .nav-links {
        display: flex;
        gap: 1.25rem;
      }
      .nav-links a {
        font-family: var(--font-ui);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--on-primary-soft);
        text-decoration: none;
      }
      .nav-links a:hover {
        color: var(--on-primary);
      }

      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }
      main.bleed {
        max-width: none;
        margin: 0;
        padding: 0;
      }

      .site-footer {
        border-top: 1px solid var(--rule);
        background: var(--primary);
      }
      .footer-inner {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1.25rem;
      }
      @media (min-width: 640px) {
        .footer-inner {
          padding: 0 2rem;
        }
      }
      .site-footer p {
        color: var(--on-primary-soft);
        font-size: 0.95rem;
        margin: 0;
        padding: 0.4rem 0;
      }
      .site-footer p:first-child {
        padding-top: 2rem;
      }
      .site-footer p:last-child {
        padding-bottom: 2.5rem;
      }
      .fineprint {
        font-size: 0.82rem !important;
        color: var(--on-primary-soft) !important;
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-display);
        font-weight: 300;
        line-height: 1.15;
        color: var(--ink);
      }
      h1 {
        font-size: clamp(2.1rem, 5vw, 3rem);
        margin: 0 0 0.5rem;
        letter-spacing: -0.01em;
      }
      h2 {
        font-size: 1.5rem;
        margin: 2.75rem 0 1rem;
      }
    </style>
  </body>
</html>
