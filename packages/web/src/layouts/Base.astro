---
interface Props {
  title: string;
  description: string;
  canonical: string;
  jsonLd?: unknown;
}
const { title, description, canonical, jsonLd } = Astro.props;
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="generator" content="My Second Country" />
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <a class="wordmark" href="/">My&nbsp;Second&nbsp;Country</a>
        <span class="tagline">cited relocation intelligence</span>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        My Second Country is run by relocators sharing sourced data, not advisers. Every
        figure links to its source and carries a verified date.
      </p>
      <p class="fineprint">&copy; {year} My Second Country. mysecondcountry.com</p>
    </footer>

    <style is:global>
      :root {
        --paper: #faf7f0;
        --paper-2: #f3ede1;
        --ink: #1c1a17;
        --ink-soft: #4a463f;
        --rule: #ddd4c4;
        --terracotta: #b5532f;
        --terracotta-dark: #8f3d1f;
        --sea: #2c6e75;
        --measure: 68ch;
        --serif: "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, "Times New Roman",
          serif;
        --sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
          sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 1.0625rem;
        line-height: 1.65;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--ink);
        color: var(--paper);
        padding: 0.6rem 1rem;
        z-index: 10;
      }
      .skip-link:focus {
        left: 0;
      }

      a {
        color: var(--terracotta-dark);
        text-underline-offset: 2px;
      }
      a:hover {
        color: var(--ink);
      }

      .site-header {
        border-bottom: 1px solid var(--rule);
        background: var(--paper);
      }
      .site-nav {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .wordmark {
        font-family: var(--serif);
        font-size: 1.3rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: var(--ink);
        text-decoration: none;
      }
      .tagline {
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

      .site-footer {
        border-top: 1px solid var(--rule);
        background: var(--paper-2);
      }
      .site-footer p {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0.4rem 1.5rem;
        color: var(--ink-soft);
        font-size: 0.95rem;
      }
      .site-footer p:first-child {
        padding-top: 2rem;
      }
      .site-footer p:last-child {
        padding-bottom: 2.5rem;
      }
      .fineprint {
        font-size: 0.82rem !important;
      }

      h1,
      h2,
      h3 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.15;
        color: var(--ink);
      }
      h1 {
        font-size: clamp(2.1rem, 5vw, 3rem);
        margin: 0 0 0.5rem;
        letter-spacing: -0.01em;
      }
      h2 {
        font-size: 1.5rem;
        margin: 2.75rem 0 1rem;
      }
    </style>
  </body>
</html>
