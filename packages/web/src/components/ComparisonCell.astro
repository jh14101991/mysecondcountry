---
import type { CitedValue } from "@where/data";
import { CONFIDENCE_DISPLAY } from "../lib/cited.ts";

interface Props {
  cited: CitedValue;
  displayValue: string;
  unit?: string;
  subtext: string;
  country: "gr" | "pt" | "es";
  isLeader: boolean;
  score: number;
  sourceRef: number;
}

const { cited, displayValue, unit, subtext, country, isLeader, score, sourceRef } = Astro.props;

const conf = CONFIDENCE_DISPLAY[cited.confidence];

const COUNTRY_FLAG: Record<string, string> = {
  gr: "🇬🇷",
  pt: "🇵🇹",
  es: "🇪🇸",
};
const COUNTRY_LABEL: Record<string, string> = {
  gr: "Greece",
  pt: "Portugal",
  es: "Spain",
};

const flagLabel = COUNTRY_FLAG[country] ?? "";
const countryLabel = COUNTRY_LABEL[country] ?? country;
---

<div class={`country-cell country-cell--${country}`} data-country={country}>
  <!-- Mobile flag label -->
  <span class="mobile-flag">{flagLabel} {countryLabel}</span>

  <!-- Value row -->
  <div class="value-row">
    <span class={`value-num value-num--${country}`}>{displayValue}</span>
    {unit && <span class="value-unit">{unit}</span>}
    {isLeader && (
      <span class={`value-arrow value-arrow--${country}`} aria-label="leads on this metric">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="7" y1="17" x2="17" y2="7"/>
          <polyline points="7 7 17 7 17 17"/>
        </svg>
      </span>
    )}
  </div>

  <!-- Subtext -->
  <p class="cell-subtext">{subtext}</p>

  <!-- Badges row -->
  <div class="cell-badges">
    <button type="button" class={`conf-badge conf-badge--${cited.confidence}`} data-confidence={cited.confidence} aria-label={`Confidence: ${conf.word}`}>
      <span aria-hidden="true">{conf.glyph}</span>
      <span>{conf.word}</span>
    </button>
    <a href={`#sources-${sourceRef}`} class="src-ref">[{sourceRef}]</a>
  </div>

  {cited.confidence === "low" && (
    <p class="low-conf-note">Reported, not verified against a primary source.</p>
  )}

  <!-- Score bar -->
  <div class="bar-wrap">
    <div
      class={`bar-fill bar-fill--${country}`}
      data-score={score}
      style={`opacity: ${isLeader ? 1 : 0.42}`}
    ></div>
  </div>
</div>

<style>
  .country-cell {
    padding: 24px 12px;
    border-left: 1px solid var(--rule-soft);
    transition: opacity 0.2s ease;
  }
  @media (min-width: 640px) {
    .country-cell {
      padding: 24px 16px;
    }
  }
  @media (min-width: 1024px) {
    .country-cell {
      padding: 24px;
    }
  }

  .mobile-flag {
    display: block;
    font-family: var(--font-ui);
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted-foreground);
    margin-bottom: 8px;
  }
  @media (min-width: 640px) {
    .mobile-flag {
      display: none;
    }
  }

  .value-row {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    flex-wrap: wrap;
    line-height: 1;
  }

  .value-num {
    font-family: var(--font-mono);
    font-size: clamp(1.4rem, 2.5vw, 2.1rem);
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .value-num--gr { color: var(--gr); }
  .value-num--pt { color: var(--pt); }
  .value-num--es { color: var(--es); }

  .value-unit {
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: 500;
    color: var(--muted-foreground);
    margin-bottom: 2px;
  }

  .value-arrow {
    margin-bottom: 2px;
    opacity: 0.7;
    display: inline-flex;
    align-items: flex-end;
  }
  .value-arrow--gr { color: var(--gr); }
  .value-arrow--pt { color: var(--pt); }
  .value-arrow--es { color: var(--es); }

  .cell-subtext {
    font-size: 11px;
    color: var(--muted-foreground);
    margin: 6px 0 0;
    line-height: 1.3;
    display: none;
  }
  @media (min-width: 640px) {
    .cell-subtext {
      display: block;
    }
  }

  .cell-badges {
    display: none;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  @media (min-width: 640px) {
    .cell-badges {
      display: flex;
    }
  }

  .conf-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-family: var(--font-ui);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 5px;
    border-radius: 2px;
    background: transparent;
  }
  .conf-badge:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }
  .conf-badge--high {
    border: 1px solid oklch(0.4693 0.1055 152.3 / 0.38);
    color: var(--conf-verified);
  }
  .conf-badge--medium {
    border: 1px solid oklch(0.4840 0.0900 95.9 / 0.38);
    color: var(--conf-good);
  }
  .conf-badge--low {
    border: 1px solid oklch(0.4432 0.0191 73.4 / 0.38);
    color: var(--conf-low);
  }

  .src-ref {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s;
  }
  .src-ref:hover {
    color: var(--ink);
  }
  .src-ref:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .low-conf-note {
    margin: 6px 0 0;
    font-size: 12px;
    color: var(--conf-low);
    line-height: 1.4;
  }

  .bar-wrap {
    margin-top: 12px;
    height: 2px;
    width: 100%;
    border-radius: 9999px;
    overflow: hidden;
    background: oklch(0.1850 0.0064 56 / 0.08);
  }
  .bar-fill {
    height: 100%;
    border-radius: 9999px;
    width: 0%;
    transition: width 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }
  .bar-fill--gr { background: var(--gr); }
  .bar-fill--pt { background: var(--pt); }
  .bar-fill--es { background: var(--es); }
</style>
