---
/**
 * The answer-first box for AI answer engines: the question as a heading, and the cited answer
 * as the first sentence below it (country, number, unit, source, date, no preamble). The
 * answer is the default slot so the page can place an inline CitedValue or a cited sentence.
 */
interface Props {
  question: string;
  headingAs?: "h2" | "h3";
  id?: string;
}
const { question, headingAs = "h2", id } = Astro.props;
const Tag = headingAs;
---

<section class="direct-answer">
  <Tag id={id} class="direct-answer-q">{question}</Tag>
  <div class="direct-answer-body">
    <slot />
  </div>
</section>

<style>
  .direct-answer {
    border-top: 1px solid var(--hairline-soft);
    padding: 1.4rem 0;
    margin: 1.5rem 0;
  }
  .direct-answer-q {
    font-family: var(--f-display);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 0.6rem;
  }
  .direct-answer-body {
    max-width: 62ch;
    font-family: var(--f-ui);
    font-size: 1.0625rem;
    line-height: 1.68;
    color: var(--ink-soft);
  }
  .direct-answer-body :global(p) {
    margin: 0 0 0.6rem;
  }
  .direct-answer-body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
