---
/**
 * A flat list of up to six internal links. Navigation, not cited data: it carries no
 * figures and emits no structured data. Used to connect an owned-rule or place page to its
 * neighbours (the country profile, the comparison).
 */
interface RelatedLink {
  label: string;
  href: string;
}
interface Props {
  links: RelatedLink[];
  heading?: string;
}
const { links, heading = "Related" } = Astro.props;
const shown = links.slice(0, 6);
---

<section class="related" aria-label={heading}>
  <h2 class="related-eyebrow">{heading}</h2>
  <ul class="related-list">
    {
      shown.map((link) => (
        <li>
          <a class="related-link" href={link.href}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .related {
    margin-top: 2.5rem;
  }
  .related-eyebrow {
    font-family: var(--f-ui);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--stone);
    margin: 0 0 0.9rem;
  }
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }
  .related-list li {
    border-bottom: 1px solid var(--hairline-soft);
    padding: 0.55rem 0;
  }
  .related-list li:first-child {
    border-top: 1px solid var(--hairline-soft);
  }
  .related-link {
    font-family: var(--f-ui);
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--ease);
  }
  .related-link:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }
  .related-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>
