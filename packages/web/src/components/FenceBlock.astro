---
import { FENCE_PRIMARY, FENCE_TAX_RESIDENCY_RIDER, stalenessBanner } from "../lib/fence.ts";

interface Props {
  /** Page carries residency, visa, or tax claims: render the rider. */
  hasLegalClaims?: boolean;
  /** If set, the most lenient breached staleness window in days: render the banner. */
  staleDays?: number | null;
}
const { hasLegalClaims = false, staleDays = null } = Astro.props;
---

<aside class="fence" role="note" aria-label="Screening notice">
  <p class="fence-primary">{FENCE_PRIMARY}</p>
  {hasLegalClaims && <p class="fence-rider">{FENCE_TAX_RESIDENCY_RIDER}</p>}
  {
    staleDays != null && (
      <p class="fence-stale" role="alert">
        {stalenessBanner(staleDays)}
      </p>
    )
  }
</aside>

<style>
  .fence {
    margin: 2rem 0;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--hairline-soft);
    border-radius: 4px;
    background: var(--tint-clay);
  }
  .fence p {
    margin: 0;
    font-family: var(--f-ui);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .fence p + p {
    margin-top: 0.6rem;
  }
  .fence-primary {
    font-weight: 600;
    color: var(--ink);
  }
  .fence-stale {
    font-weight: 600;
    color: var(--ink);
  }
</style>
