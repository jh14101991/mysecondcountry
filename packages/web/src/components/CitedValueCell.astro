---
import type { CitedValue, Granularity } from "@where/data";

interface Props {
  cited: CitedValue;
  unit?: string;
  placeGranularity: Granularity;
  placeName: string;
  /** Render the value as normal-size prose (for long string claims like a tax regime). */
  prose?: boolean;
}
const { cited, unit, placeGranularity, placeName, prose = false } = Astro.props;

// Confidence renders as icon PLUS text so it never depends on colour alone (DOD j).
const BADGE: Record<CitedValue["confidence"], { icon: string; label: string }> = {
  high: { icon: "●", label: "verified source" },
  medium: { icon: "◐", label: "good source" },
  low: { icon: "○", label: "low confidence, verify" },
};
const badge = BADGE[cited.confidence];

// Granularity honesty (ADR-0003): label any figure broader than the place itself.
const granularityNote =
  cited.granularity !== placeGranularity && cited.granularity === "country"
    ? `National figure shown for ${placeName}`
    : cited.granularity !== placeGranularity && cited.granularity === "region"
      ? `Regional figure shown for ${placeName}`
      : null;

const valueText = unit ? `${cited.value} ${unit}` : `${cited.value}`;
---

<td class="cited">
  <span class={prose ? "value value-prose" : "value"}>{valueText}</span>
  <span class={`badge badge-${cited.confidence}`}>
    <span class="badge-icon" aria-hidden="true">{badge.icon}</span>
    <span class="badge-text">{badge.label}</span>
  </span>
  {granularityNote && <span class="granularity">{granularityNote}</span>}
  <span class="provenance">
    <a href={cited.sourceUrl} rel="noopener nofollow" target="_blank">{cited.sourceName}</a>
    <span class="verified">Verified {cited.verifiedDate}</span>
  </span>
  {cited.excerpt && <span class="excerpt">{cited.excerpt}</span>}
</td>

<style>
  .cited {
    padding: 0.9rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid var(--rule);
  }
  .value {
    display: block;
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
  }
  .value-prose {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.35rem;
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--rule);
  }
  .badge-icon {
    font-size: 0.9rem;
    line-height: 1;
  }
  .badge-high {
    color: #1f5132;
    border-color: #9ec9ac;
    background: #eef6f0;
  }
  .badge-medium {
    color: #6b4a12;
    border-color: #d9c08a;
    background: #f8f1de;
  }
  .badge-low {
    color: #7a1f1f;
    border-color: #d9a3a3;
    background: #f8e9e9;
  }
  .granularity {
    display: block;
    margin-top: 0.5rem;
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .provenance {
    display: block;
    margin-top: 0.55rem;
    font-size: 0.88rem;
  }
  .provenance a {
    display: inline;
  }
  .verified {
    display: block;
    color: var(--ink-soft);
    font-size: 0.82rem;
    margin-top: 0.15rem;
  }
  .excerpt {
    display: block;
    margin-top: 0.6rem;
    padding-left: 0.8rem;
    border-left: 2px solid var(--rule);
    color: var(--ink-soft);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
