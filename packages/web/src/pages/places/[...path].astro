---
import {
  type CitedValue,
  collectCitedValues,
  DEFAULT_STALENESS_DAYS,
  isStale,
  type Place,
  placePath,
  places,
} from "@where/data";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FactsTable from "../../components/FactsTable.astro";
import FenceBlock from "../../components/FenceBlock.astro";
import Masthead from "../../components/Masthead.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Base from "../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  maxVerifiedDate,
  placeDatasetJsonLd,
  placeJsonLd,
} from "../../lib/jsonld.ts";

export function getStaticPaths() {
  return places.map((place) => ({
    params: { path: [...place.ancestry.map((a) => a.slug), place.slug].join("/") },
    props: { place },
  }));
}

interface Props {
  place: Place;
}
const { place } = Astro.props;

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}${placePath(place)}`;
const hasLegalClaims = Boolean(place.residency || place.tax);
const title = `${place.name}: cited cost, climate, residency and tax facts | My Second Country`;

const allFacts = collectCitedValues(place);
const maxDate = maxVerifiedDate(allFacts.map((f) => f.cited));
const uniqueSources = new Set(allFacts.map((f) => f.cited.sourceUrl));
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: uniqueSources.size,
});

// Self-activating staleness banner: if any claim has aged past its window before a
// refresh merges, the banner appears automatically at build time (FENCE.md).
const stale = allFacts.filter((e) => isStale(e.cited));
const staleDays = stale.length
  ? Math.min(
      ...stale.map(
        (e) =>
          e.cited.stalenessDays ??
          (e.cited.category ? DEFAULT_STALENESS_DAYS[e.cited.category] : 180),
      ),
    )
  : null;

// Breadcrumbs: link an ancestor only when its place page actually exists in the dataset,
// so we never emit a crumb that 404s.
const validPaths = new Set(places.map((p) => placePath(p)));
const breadcrumbItems = [
  // Only include ancestors that resolve to a real page, so every JSON-LD ListItem
  // carries an `item` URL (Google rejects a breadcrumb item without one).
  ...place.ancestry
    .map((ancestor, i) => {
      const path = `/places/${place.ancestry
        .slice(0, i + 1)
        .map((a) => a.slug)
        .join("/")}`;
      return validPaths.has(path) ? { name: ancestor.name, href: path } : null;
    })
    .filter((c): c is { name: string; href: string } => c !== null),
  { name: place.name, href: placePath(place) },
];

interface Row {
  label: string;
  cited: CitedValue;
  unit?: string;
  prose?: boolean;
}

const costClimate: Row[] = [
  { label: "Cost of living (price level index)", cited: place.costOfLiving.priceLevelIndexEU27 },
  { label: "Average January high", cited: place.climate.averageJanuaryHighC, unit: "°C" },
  { label: "Average July high", cited: place.climate.averageJulyHighC, unit: "°C" },
  { label: "Annual sunshine", cited: place.climate.averageAnnualSunHours, unit: "hours" },
  { label: "Climate classification", cited: place.climate.koppenClass },
];

const residencyTax: Row[] = [];
if (place.residency) {
  residencyTax.push({
    label: "Digital nomad visa, minimum net income",
    cited: place.residency.digitalNomadVisa,
    unit: "EUR/month",
  });
  if (place.residency.goldenVisa) {
    residencyTax.push({
      label: "Golden visa / investor residency",
      cited: place.residency.goldenVisa,
      prose: true,
    });
  }
}
if (place.tax) {
  residencyTax.push({
    label: "Top personal income tax rate",
    cited: place.tax.headlinePersonalIncomeTaxRate,
    unit: "%",
  });
  if (place.tax.specialRegime) {
    residencyTax.push({
      label: "Special tax regime for movers",
      cited: place.tax.specialRegime,
      prose: true,
    });
  }
}

const healthSafety: Row[] = [];
if (place.healthcare) {
  healthSafety.push({
    label: "Physicians per 1,000 people",
    cited: place.healthcare.physiciansPer1000,
  });
}
if (place.safety) {
  healthSafety.push({
    label: "Global Peace Index score (lower is safer)",
    cited: place.safety.peaceIndexScore,
  });
}

const jsonLd = [
  placeJsonLd(place, SITE),
  placeDatasetJsonLd(place, SITE),
  articleJsonLd({
    url: canonical,
    headline: place.name,
    description: place.description,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
];
---

<Base title={title} description={place.description} canonical={canonical} jsonLd={jsonLd}>
  <article>
    <Breadcrumb items={breadcrumbItems} />

    <Masthead variant="place" title={place.name} dateline={dateline} />

    <FenceBlock hasLegalClaims={hasLegalClaims} staleDays={staleDays} />

    <p class="lede">{place.description}</p>

    <section aria-labelledby="cost-climate-h">
      <SectionHeading as="h2" id="cost-climate-h">Cost and climate</SectionHeading>
      <FactsTable
        caption={`Cited cost and climate facts for ${place.name}`}
        rows={costClimate}
        placeGranularity={place.granularity}
        placeName={place.name}
      />
    </section>

    {
      residencyTax.length > 0 && (
        <section aria-labelledby="residency-tax-h">
          <SectionHeading as="h2" id="residency-tax-h">
            Residency and tax
          </SectionHeading>
          <p class="section-note">
            These are published national rules reported from their source on the verified date.
            They are not advice and they change. Confirm your own position with a licensed
            professional and the official source.
          </p>
          <FactsTable
            caption={`Cited residency and tax facts for ${place.name}`}
            rows={residencyTax}
            placeGranularity={place.granularity}
            placeName={place.name}
          />
        </section>
      )
    }

    {
      healthSafety.length > 0 && (
        <section aria-labelledby="health-safety-h">
          <SectionHeading as="h2" id="health-safety-h">
            Healthcare and safety
          </SectionHeading>
          <FactsTable
            caption={`Cited healthcare and safety facts for ${place.name}`}
            rows={healthSafety}
            placeGranularity={place.granularity}
            placeName={place.name}
          />
        </section>
      )
    }

    <section aria-labelledby="how-to-read-h" class="how-to-read">
      <SectionHeading as="h2" id="how-to-read-h">How to read this page</SectionHeading>
      <p>
        Every figure above is a cited claim: a value, the named source, the date we last verified
        it, and a confidence mark. Verified means an official statistical body or primary law. Good
        means an official authority read through a secondary. Limited means a directional figure to
        check yourself. A national figure shown for a town is labelled as such; we do not pass a
        country average off as a local one.
      </p>
    </section>

    {/* Screening island placeholder. No client JavaScript yet; the interactive
        screener mounts here in a later phase. */}
    <div id="screening-island" data-place-id={place.id} hidden></div>
  </article>

  <style>
    .lede {
      max-width: var(--measure);
      font-family: var(--font-serif);
      font-size: 1.2rem;
      line-height: 1.55;
      color: var(--muted-strong);
      margin: 0 0 0.5rem;
    }
    .section-note {
      max-width: var(--measure);
      color: var(--muted-foreground);
      font-family: var(--font-serif);
      font-size: 0.98rem;
    }
    .how-to-read {
      margin-top: 3rem;
      padding: 1.4rem 1.5rem;
      background: var(--card);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
    }
    .how-to-read :global(.section-heading--heading) {
      margin-top: 0;
    }
    .how-to-read p {
      max-width: var(--measure);
      margin: 0;
      font-family: var(--font-serif);
      color: var(--muted-strong);
    }
  </style>
</Base>
