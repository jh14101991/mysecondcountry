---
import type { CitedValue as DataCitedValue, MatrixRow, Place } from "@where/data";
import {
  collectCitedValues,
  DEFAULT_STALENESS_DAYS,
  isStale,
  placeEvidenceBundleById,
  placePath,
  places,
} from "@where/data";
import { loadRouteContract, routeIsHeld } from "../../../../../scripts/lib/route-contract.ts";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CitedValue from "../../components/CitedValue.astro";
import ConfidenceMark from "../../components/ConfidenceMark.astro";
import FenceBlock from "../../components/FenceBlock.astro";
import Masthead from "../../components/Masthead.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import SourcesList from "../../components/SourcesList.astro";
import Base from "../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  maxVerifiedDate,
  placeDatasetJsonLd,
  placeJsonLd,
} from "../../lib/jsonld.ts";

export function getStaticPaths() {
  return places.map((place) => ({
    params: { path: [...place.ancestry.map((a) => a.slug), place.slug].join("/") },
    props: { place },
  }));
}

interface Props {
  place: Place;
}
const { place } = Astro.props;
const evidenceBundle = placeEvidenceBundleById(place.id);

const SITE = "https://mysecondcountry.com";
const routePath = placePath(place);
const canonical = `${SITE}${routePath}`;
const routeContract = loadRouteContract();
const isHeldCoverage = routeIsHeld(routeContract, routePath);
const heldCoverageDescription = `${place.name} coverage is held while its evidence bundle remains under publication review. No local dossier facts are published yet.`;
const pageDescription = isHeldCoverage ? heldCoverageDescription : place.description;
const hasLegalClaims = !isHeldCoverage && Boolean(place.residency || place.tax);
const title = isHeldCoverage
  ? `${place.name}: coverage held pending source review | My Second Country`
  : `${place.name}: cited cost, climate, residency and tax facts | My Second Country`;

const allFacts: ReturnType<typeof collectCitedValues> = isHeldCoverage
  ? []
  : collectCitedValues(place);
const maxDate = isHeldCoverage ? "2026-06-29" : maxVerifiedDate(allFacts.map((f) => f.cited));
const uniqueSources = new Set(allFacts.map((f) => f.cited.sourceUrl));
const dateline = isHeldCoverage
  ? "Coverage held, publication gate active"
  : buildDateline({
      citedLabel: monthYearLabel(maxDate),
      sourceCount: uniqueSources.size,
    });

// Self-activating staleness banner: if any claim has aged past its window before a
// refresh merges, the banner appears automatically at build time (FENCE.md).
const stale = allFacts.filter((e) => isStale(e.cited));
const staleDays = stale.length
  ? Math.min(
      ...stale.map(
        (e) =>
          e.cited.stalenessDays ??
          (e.cited.category ? DEFAULT_STALENESS_DAYS[e.cited.category] : 180),
      ),
    )
  : null;

// Breadcrumbs: link an ancestor only when its place page actually exists in the dataset,
// so we never emit a crumb that 404s.
const validPaths = new Set(places.map((p) => placePath(p)));
const breadcrumbItems = [
  // Only include ancestors that resolve to a real page, so every JSON-LD ListItem
  // carries an `item` URL (Google rejects a breadcrumb item without one).
  ...place.ancestry
    .map((ancestor, i) => {
      const path = `/places/${place.ancestry
        .slice(0, i + 1)
        .map((a) => a.slug)
        .join("/")}`;
      return validPaths.has(path) ? { name: ancestor.name, href: path } : null;
    })
    .filter((c): c is { name: string; href: string } => c !== null),
  { name: place.name, href: routePath },
];

interface Row {
  label: string;
  cited: DataCitedValue;
  unit?: string;
  prose?: boolean;
}

function sourceGapMessage(row: MatrixRow): string {
  if (
    [
      "airport_winter_direct_destinations",
      "airport_winter_route_ratio",
      "ferry_routes_winter",
      "ferry_routes_summer",
    ].includes(row.key)
  ) {
    return "Official seasonal count not publishable yet. Public official pages checked did not expose a reusable dated count for this season; this is not zero service and not an inferred count.";
  }
  if (["rent_1bed_city", "grocery_basket", "restaurant_meal", "beer_price"].includes(row.key)) {
    return "Licensed source required. A source family exists, but My Second Country does not republish paywalled city-price rows without approved access.";
  }
  if (
    [
      "vegan_friendly",
      "sale_inventory_count",
      "rent_inventory_count",
      "long_let_inventory_count",
      "furnished_rental_share",
      "asking_rent_sqm",
      "rental_supply_seasonality",
      "pet_friendly_rental_proxy",
    ].includes(row.key)
  ) {
    return "Reuse rights not cleared. We do not scrape or republish portal or listing counts without written permission or a licensed feed.";
  }
  if (["transit_pass", "recorded_crime", "noise_pollution"].includes(row.key)) {
    return "No comparable public source found for this geography in this pass; this is not a zero value.";
  }
  if (["tax_treaty", "totalization_agreement", "flight_time_home"].includes(row.key)) {
    return "Reader-specific row, computed only when a home country or home hub is supplied; this is not a fixed Chania fact.";
  }
  return "Evaluated in the evidence bundle, but no publishable fixed value is available for this page yet.";
}

const MATRIX_CATEGORY_LABELS: Record<MatrixRow["matrixCategory"], string> = {
  identity: "Identity",
  money: "Money",
  tax_residency: "Tax and residency",
  climate: "Climate",
  travel_connectivity: "Travel and connectivity",
  health_family_schooling: "Health, family and schooling",
  safety_rights: "Safety and rights",
  nature_environment: "Nature and environment",
  culture_services: "Culture and services",
};

const COVERAGE_LABELS: Record<MatrixRow["coverageStatus"], string> = {
  local: "Local",
  regional: "Regional",
  national: "National",
  inherited_national: "Inherited national",
  inherited_regional: "Inherited regional",
  proxy: "Proxy",
  relational: "Relational",
  unavailable: "Unavailable",
  blocked: "Blocked",
  deferred: "Deferred",
};

const LENS_BUTTONS = [
  { id: "all", label: "All rows" },
  { id: "family", label: "Family" },
  { id: "housing", label: "Housing" },
  { id: "mobility", label: "Mobility" },
  { id: "climate", label: "Climate" },
  { id: "health", label: "Health" },
  { id: "tax-residency", label: "Tax and residency" },
  { id: "lifestyle", label: "Lifestyle" },
  { id: "remote-work", label: "Remote work" },
  { id: "local-proof", label: "Local proof" },
  { id: "source-gaps", label: "Source gaps" },
] as const;

const HOUSING_KEYS = new Set([
  "hpi",
  "property_sqm_city",
  "mortgage_rate",
  "rent_to_income",
  "housing_overburden",
  "rent_1bed_city",
  "sale_inventory_count",
  "rent_inventory_count",
  "long_let_inventory_count",
  "furnished_rental_share",
  "asking_rent_sqm",
  "rental_supply_seasonality",
  "property_transfer_tax",
  "annual_property_tax",
  "land_registry_office_distance",
  "short_term_rental_density",
  "pet_friendly_rental_proxy",
]);
const REMOTE_WORK_KEYS = new Set([
  "broadband_price",
  "mobile_price",
  "broadband_speed",
  "mobile_speed",
  "coworking_space_count",
  "timezone_offset",
  "company_formation",
  "dnv_income_floor",
  "startup_visa",
]);
const PET_KEYS = new Set([
  "dog_park_vet",
  "vet_density",
  "dog_park_count",
  "pet_import_rules",
  "pet_friendly_rental_proxy",
  "emergency_vet_proxy",
]);

type AtlasRow = {
  key: string;
  label: string;
  categoryLabel: string;
  coverageLabel: string;
  statusTone: "cited" | "gap" | "inherited" | "local" | "proxy";
  lensTokens: string[];
  lensAttr: string;
  value: string;
  hasCitation: boolean;
  confidence?: DataCitedValue["confidence"];
  sourceUrl?: string;
  sourceName?: string;
  verifiedDate?: string;
  excerpt?: string;
  notes?: string;
  gapMessage?: string;
  granularityLabel: string;
  searchText: string;
};

function formatAtlasScalar(value: unknown): string {
  if (typeof value === "boolean") return value ? "Yes" : "No";
  if (typeof value === "number") {
    return value.toLocaleString("en-GB", { maximumFractionDigits: 2 });
  }
  return String(value);
}

function formatAtlasValue(row: MatrixRow): string {
  if (!row.cited) return sourceGapMessage(row);
  const value = formatAtlasScalar(row.cited.value);
  if (!row.unit || row.key === "temp_monthly_high") return value;
  if (typeof row.cited.value === "string") return value;
  return `${value} ${row.unit}`;
}

function statusTone(row: MatrixRow): AtlasRow["statusTone"] {
  if (row.sourceGapReason) return "gap";
  if (row.coverageStatus === "local") return "local";
  if (row.coverageStatus === "proxy") return "proxy";
  if (row.coverageStatus === "inherited_national" || row.coverageStatus === "inherited_regional") {
    return "inherited";
  }
  return "cited";
}

function lensesFor(row: MatrixRow): string[] {
  const lenses = new Set<string>();
  if (row.matrixCategory === "money") lenses.add("money");
  if (row.matrixCategory === "tax_residency") lenses.add("tax-residency");
  if (row.matrixCategory === "climate") lenses.add("climate");
  if (row.matrixCategory === "travel_connectivity") lenses.add("mobility");
  if (row.matrixCategory === "nature_environment") {
    lenses.add("climate");
    lenses.add("lifestyle");
  }
  if (row.matrixCategory === "health_family_schooling") {
    lenses.add("health");
    lenses.add("family");
  }
  if (row.matrixCategory === "safety_rights") lenses.add("safety");
  if (row.matrixCategory === "culture_services") lenses.add("lifestyle");
  if (HOUSING_KEYS.has(row.key)) lenses.add("housing");
  if (REMOTE_WORK_KEYS.has(row.key)) lenses.add("remote-work");
  if (PET_KEYS.has(row.key)) lenses.add("lifestyle");
  if (row.key.includes("school") || row.key.includes("child") || row.key.includes("family")) {
    lenses.add("family");
  }
  if (row.coverageStatus === "local" || row.observedGranularity === "town") {
    lenses.add("local-proof");
  }
  if (row.sourceGapReason) lenses.add("source-gaps");
  return [...lenses];
}

function toAtlasRow(row: MatrixRow): AtlasRow {
  const value = formatAtlasValue(row);
  const lensTokens = lensesFor(row);
  const granularityLabel = row.observedGranularity
    ? `${row.observedGranularity} observed, ${row.intendedGranularity} intended`
    : `${row.intendedGranularity} intended`;
  const searchable = [
    row.key,
    row.label,
    MATRIX_CATEGORY_LABELS[row.matrixCategory],
    COVERAGE_LABELS[row.coverageStatus],
    value,
    row.cited?.sourceName,
    row.cited?.excerpt,
    row.notes,
    row.sourceGapReason ? sourceGapMessage(row) : undefined,
    ...lensTokens,
  ]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
  return {
    key: row.key,
    label: row.label,
    categoryLabel: MATRIX_CATEGORY_LABELS[row.matrixCategory],
    coverageLabel: COVERAGE_LABELS[row.coverageStatus],
    statusTone: statusTone(row),
    lensTokens,
    lensAttr: lensTokens.join(" "),
    value,
    hasCitation: Boolean(row.cited),
    confidence: row.cited?.confidence,
    sourceUrl: row.cited?.sourceUrl,
    sourceName: row.cited?.sourceName,
    verifiedDate: row.cited?.verifiedDate,
    excerpt: row.cited?.excerpt,
    notes: row.notes,
    gapMessage: row.sourceGapReason ? sourceGapMessage(row) : undefined,
    granularityLabel,
    searchText: searchable,
  };
}

const atlasRows: AtlasRow[] =
  !isHeldCoverage && evidenceBundle ? evidenceBundle.rows.map((row) => toAtlasRow(row)) : [];
const atlasJson = JSON.stringify(atlasRows).replace(/</g, "\\u003c");
const atlasCitedCount = atlasRows.filter((row) => row.hasCitation).length;
const atlasGapCount = atlasRows.filter((row) => row.gapMessage).length;
const atlasLocalCount = atlasRows.filter((row) => row.statusTone === "local").length;
const atlasProxyCount = atlasRows.filter((row) => row.statusTone === "proxy").length;
const atlasInheritedCount = atlasRows.filter((row) => row.statusTone === "inherited").length;
const atlasFirstRow = atlasRows[0];

const costClimate: Row[] = [
  { label: "Cost of living (price level index)", cited: place.costOfLiving.priceLevelIndexEU27 },
  { label: "Average January high", cited: place.climate.averageJanuaryHighC, unit: "°C" },
  { label: "Average July high", cited: place.climate.averageJulyHighC, unit: "°C" },
  { label: "Annual sunshine", cited: place.climate.averageAnnualSunHours, unit: "hours" },
  { label: "Climate classification", cited: place.climate.koppenClass },
];

const residencyTax: Row[] = [];
if (place.residency) {
  residencyTax.push({
    label: "Digital nomad visa, minimum net income",
    cited: place.residency.digitalNomadVisa,
    unit: "EUR/month",
  });
  if (place.residency.goldenVisa) {
    residencyTax.push({
      label: "Golden visa / investor residency",
      cited: place.residency.goldenVisa,
      prose: true,
    });
  }
}
if (place.tax) {
  residencyTax.push({
    label: "Top personal income tax rate",
    cited: place.tax.headlinePersonalIncomeTaxRate,
    unit: "%",
  });
  if (place.tax.specialRegime) {
    residencyTax.push({
      label: "Special tax regime for movers",
      cited: place.tax.specialRegime,
      prose: true,
    });
  }
}

const healthSafety: Row[] = [];
if (place.healthcare) {
  healthSafety.push({
    label: "Physicians per 1,000 people",
    cited: place.healthcare.physiciansPer1000,
  });
}
if (place.safety) {
  healthSafety.push({
    label: "Global Peace Index score (lower is safer)",
    cited: place.safety.peaceIndexScore,
  });
}

// Direct child places (regions, towns) for the "Regions and towns" links.
const childPlaces = places.filter((p) => p.parentId === place.id);

type InternalLink = { label: string; href: string };
const placeClusterMap: Record<string, { heading: string; links: InternalLink[] }> = {
  gr: {
    heading: "Greece evidence cluster",
    links: [
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      {
        label: "Greece non-dom 100,000 euro lump-sum tax",
        href: "/greece/tax/non-dom-lump-sum-tax",
      },
      { label: "Greece golden visa price tiers", href: "/topics/greece-golden-visa-price-tiers" },
      { label: "Crete region dossier", href: "/places/greece/crete" },
      { label: "Chania town dossier", href: "/places/greece/crete/chania" },
      {
        label: "Greece 7 percent pension tax checklist",
        href: "/tools/greece-7-percent-pension-tax-checklist",
      },
    ],
  },
  "gr-crete": {
    heading: "Crete evidence cluster",
    links: [
      { label: "Greece country dossier", href: "/places/greece" },
      { label: "Chania town dossier", href: "/places/greece/crete/chania" },
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      {
        label: "Greece non-dom 100,000 euro lump-sum tax",
        href: "/greece/tax/non-dom-lump-sum-tax",
      },
      { label: "Greece golden visa price tiers", href: "/topics/greece-golden-visa-price-tiers" },
    ],
  },
  "gr-crete-chania": {
    heading: "Chania evidence cluster",
    links: [
      { label: "Crete region dossier", href: "/places/greece/crete" },
      { label: "Greece country dossier", href: "/places/greece" },
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      {
        label: "Greece 7 percent pension tax checklist",
        href: "/tools/greece-7-percent-pension-tax-checklist",
      },
      { label: "Greece golden visa price tiers", href: "/topics/greece-golden-visa-price-tiers" },
    ],
  },
  pt: {
    heading: "Portugal IFICI cluster",
    links: [
      { label: "Portugal IFICI 20 percent regime", href: "/portugal/tax/ifici" },
      {
        label: "Is Portugal's NHR tax regime still available?",
        href: "/answers/is-portugals-nhr-tax-regime-still-available",
      },
      { label: "Portugal IFICI, the NHR successor", href: "/topics/portugal-ifici-the-nhr-successor" },
      {
        label: "Portugal IFICI eligibility checklist",
        href: "/tools/portugal-ifici-eligibility-checklist",
      },
      {
        label: "Greece vs Portugal vs Spain comparison",
        href: "/compare/greece-portugal-spain",
      },
    ],
  },
  it: {
    heading: "Italy pension tax context",
    links: [
      {
        label: "Italy pensioner 7 percent flat tax",
        href: "/italy/tax/pensioner-7-percent-flat-tax",
      },
      {
        label: "EU expat tax regimes by rate",
        href: "/shortlists/eu-expat-tax-regimes-by-rate",
      },
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      {
        label: "Greece vs Portugal vs Spain comparison",
        href: "/compare/greece-portugal-spain",
      },
    ],
  },
};
const placeCluster = placeClusterMap[place.id];
const placeClusterLinks = placeCluster
  ? placeCluster.links.filter((link) => link.href !== routePath)
  : [];

// Sources on this page: deduplicated by URL, ordered by first appearance.
const pageSources: { url: string; name: string; verifiedDate: string }[] = [];
const seenSourceUrls = new Set<string>();
for (const { cited } of allFacts) {
  if (seenSourceUrls.has(cited.sourceUrl)) continue;
  seenSourceUrls.add(cited.sourceUrl);
  pageSources.push({
    url: cited.sourceUrl,
    name: cited.sourceName,
    verifiedDate: cited.verifiedDate,
  });
}
for (const row of atlasRows) {
  if (!row.sourceUrl || !row.sourceName || !row.verifiedDate) continue;
  if (seenSourceUrls.has(row.sourceUrl)) continue;
  seenSourceUrls.add(row.sourceUrl);
  pageSources.push({
    url: row.sourceUrl,
    name: row.sourceName,
    verifiedDate: row.verifiedDate,
  });
}

const heldPlaceJsonLd = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": canonical,
  name: place.name,
  url: canonical,
};

const jsonLd = isHeldCoverage
  ? [
      heldPlaceJsonLd,
      articleJsonLd({
        url: canonical,
        headline: `${place.name} coverage held`,
        description: pageDescription,
        dateModified: maxDate,
        siteUrl: SITE,
      }),
      breadcrumbJsonLd(breadcrumbItems, SITE),
    ]
  : [
      placeJsonLd(place, SITE),
      placeDatasetJsonLd(place, SITE),
      articleJsonLd({
        url: canonical,
        headline: place.name,
        description: pageDescription,
        dateModified: maxDate,
        siteUrl: SITE,
      }),
      breadcrumbJsonLd(breadcrumbItems, SITE),
    ];
---

<Base title={title} description={pageDescription} canonical={canonical} jsonLd={jsonLd}>
  <article class:list={[isHeldCoverage && "held-coverage"]}>
    <Breadcrumb items={breadcrumbItems} />

    <Masthead variant="place" title={place.name} dateline={dateline} />

    <FenceBlock hasLegalClaims={hasLegalClaims} staleDays={staleDays} />

    {
      isHeldCoverage ? (
        <>
          <section class="hold-panel" aria-labelledby="held-state-h">
            <p class="held-kicker">Coverage hold</p>
            <SectionHeading as="h2" id="held-state-h">
              This is not a town dossier yet
            </SectionHeading>
            <p class="lede">{heldCoverageDescription}</p>
            <p>
              The route stays public so the coverage map has a stable {place.name} status page. It
              does not publish local cost, residency, tax, climate, healthcare, or living claims.
            </p>
          </section>

          <section class="held-grid" aria-labelledby="held-gate-h">
            <div class="held-box">
              <SectionHeading as="h2" id="held-gate-h">
                What is held
              </SectionHeading>
              <ul class="held-list">
                <li>Local fact tables</li>
                <li>Town source table</li>
                <li>Dataset JSON-LD and measured variables</li>
                <li>Answer-first dossier summary</li>
              </ul>
            </div>
            <div class="held-box">
              <SectionHeading as="h2" id="held-next-h">
                Gate to clear
              </SectionHeading>
              <ul class="held-list">
                <li>Parent-region evidence bundle clears publication review</li>
                <li>Town evidence bundle clears publication review</li>
                <li>Page Factory renders the dossier from cited town evidence</li>
              </ul>
            </div>
          </section>

          <section class="held-next-actions" aria-labelledby="held-actions-h">
            <SectionHeading as="h2" id="held-actions-h">
              Available routes
            </SectionHeading>
            <p>
              The current public surfaces still show the source standard, country-level comparison,
              and screening boundary.
            </p>
            <div class="held-actions">
              <a href="/sources" class="btn-primary">Inspect sources</a>
              <a href="/methodology" class="text-link">Read methodology</a>
              <a href="/compare/greece-portugal-spain" class="text-link">Compare countries</a>
            </div>
          </section>
        </>
      ) : (
        <>
          <p class="lede">{place.description}</p>

          {atlasRows.length > 0 && (
            <section class="evidence-atlas" aria-labelledby="evidence-atlas-h" data-evidence-atlas>
              <div class="atlas-heading">
                <span class="atlas-kicker">Evidence atlas</span>
                <SectionHeading as="h2" id="evidence-atlas-h">
                  254-row Chania dossier
                </SectionHeading>
                <p class="section-note">
                  The atlas keeps local facts, inherited national facts, proxy rows, and source
                  gaps in one navigable record. It is screening intelligence, not advice.
                </p>
              </div>

              <dl class="atlas-metrics" aria-label="Evidence bundle summary">
                <div>
                  <dt>Rows attempted</dt>
                  <dd>{atlasRows.length}</dd>
                </div>
                <div>
                  <dt>Cited rows</dt>
                  <dd>{atlasCitedCount}</dd>
                </div>
                <div>
                  <dt>Source gaps</dt>
                  <dd>{atlasGapCount}</dd>
                </div>
                <div>
                  <dt>Local rows</dt>
                  <dd>{atlasLocalCount}</dd>
                </div>
                <div>
                  <dt>Proxy rows</dt>
                  <dd>{atlasProxyCount}</dd>
                </div>
                <div>
                  <dt>Inherited rows</dt>
                  <dd>{atlasInheritedCount}</dd>
                </div>
              </dl>

              <div class="atlas-controls" aria-label="Evidence filters">
                <div class="atlas-lenses" role="group" aria-label="Reader lens">
                  {LENS_BUTTONS.map((lens, index) => (
                    <button
                      type="button"
                      class:list={["atlas-lens", index === 0 && "is-active"]}
                      data-atlas-lens={lens.id}
                      aria-pressed={index === 0 ? "true" : "false"}
                    >
                      {lens.label}
                    </button>
                  ))}
                </div>
                <label class="atlas-search">
                  <span>Search evidence</span>
                  <input
                    type="search"
                    data-atlas-search
                    autocomplete="off"
                    placeholder="airport, rent, school, tax"
                  />
                </label>
              </div>

              <div class="atlas-grid">
