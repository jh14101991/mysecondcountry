              <script type="application/json" data-atlas-data set:html={atlasJson}></script>
              <script is:inline>
                (() => {
                  for (const root of document.querySelectorAll("[data-evidence-atlas]")) {
                    const dataNode = root.querySelector("[data-atlas-data]");
                    const rows = JSON.parse(dataNode?.textContent || "[]");
                    const buttons = [...root.querySelectorAll("[data-atlas-row]")];
                    const lenses = [...root.querySelectorAll("[data-atlas-lens]")];
                    const search = root.querySelector("[data-atlas-search]");
                    const count = root.querySelector("[data-atlas-count]");
                    const detail = root.querySelector("[data-atlas-detail]");
                    let activeLens = "all";
                    let activeKey = buttons[0]?.dataset.key || "";

                    const fields = {
                      state: detail?.querySelector("[data-detail-state]"),
                      label: detail?.querySelector("[data-detail-label]"),
                      key: detail?.querySelector("[data-detail-key]"),
                      value: detail?.querySelector("[data-detail-value]"),
                      category: detail?.querySelector("[data-detail-category]"),
                      granularity: detail?.querySelector("[data-detail-granularity]"),
                      confidenceRow: detail?.querySelector("[data-detail-confidence-row]"),
                      confidence: detail?.querySelector("[data-detail-confidence]"),
                      verifiedRow: detail?.querySelector("[data-detail-verified-row]"),
                      verified: detail?.querySelector("[data-detail-verified]"),
                      note: detail?.querySelector("[data-detail-note]"),
                      excerpt: detail?.querySelector("[data-detail-excerpt]"),
                      gap: detail?.querySelector("[data-detail-gap]"),
                      sourceRow: detail?.querySelector("[data-detail-source-row]"),
                      source: detail?.querySelector("[data-detail-source]"),
                    };

                    function setText(node, value) {
                      if (!node) return;
                      node.textContent = value || "";
                      node.hidden = !value;
                    }

                    function setDetail(row) {
                      if (!row || !detail) return;
                      fields.state.textContent = row.coverageLabel;
                      fields.state.className = `atlas-detail-state atlas-detail-state--${row.statusTone}`;
                      setText(fields.label, row.label);
                      setText(fields.key, row.key);
                      setText(fields.value, row.value);
                      setText(fields.category, row.categoryLabel);
                      setText(fields.granularity, row.granularityLabel);
                      fields.confidenceRow.hidden = !row.confidence;
                      setText(fields.confidence, row.confidence);
                      fields.verifiedRow.hidden = !row.verifiedDate;
                      setText(fields.verified, row.verifiedDate);
                      setText(fields.note, row.notes);
                      setText(fields.excerpt, row.excerpt);
                      setText(fields.gap, row.gapMessage);
                      fields.sourceRow.hidden = !row.sourceUrl;
                      if (fields.source && row.sourceUrl) {
                        fields.source.textContent = row.sourceName || row.sourceUrl;
                        fields.source.href = row.sourceUrl;
                      }
                    }

                    function selectRow(key) {
                      activeKey = key;
                      for (const button of buttons) {
                        button.setAttribute("aria-pressed", button.dataset.key === key ? "true" : "false");
                      }
                      setDetail(rows.find((row) => row.key === key));
                    }

                    function applyFilters() {
                      const query = (search?.value || "").trim().toLowerCase();
                      let visible = 0;
                      let firstVisible = "";
                      for (const button of buttons) {
                        const lensMatch =
                          activeLens === "all" ||
                          (button.dataset.lenses || "").split(" ").includes(activeLens);
                        const searchMatch = !query || (button.dataset.search || "").includes(query);
                        const show = lensMatch && searchMatch;
                        button.hidden = !show;
                        if (show) {
                          visible += 1;
                          firstVisible ||= button.dataset.key || "";
                        }
                      }
                      if (count) count.textContent = String(visible);
                      const activeButton = buttons.find(
                        (button) => button.dataset.key === activeKey && !button.hidden,
                      );
                      if (!activeButton && firstVisible) selectRow(firstVisible);
                    }

                    for (const button of buttons) {
                      button.addEventListener("click", () => selectRow(button.dataset.key || ""));
                    }
                    for (const lens of lenses) {
                      lens.addEventListener("click", () => {
                        activeLens = lens.dataset.atlasLens || "all";
                        for (const other of lenses) {
                          const pressed = other === lens;
                          other.classList.toggle("is-active", pressed);
                          other.setAttribute("aria-pressed", pressed ? "true" : "false");
                        }
                        applyFilters();
                      });
                    }
                    search?.addEventListener("input", applyFilters);
                    if (activeKey) selectRow(activeKey);
                  }
                })();
              </script>
            </section>
          )}

