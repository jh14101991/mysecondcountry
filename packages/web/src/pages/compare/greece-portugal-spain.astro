---
import type { CitedValue } from "@where/data";
import { placeById } from "@where/data";
import ConfidenceMark from "../../components/ConfidenceMark.astro";
import FaqItem from "../../components/FaqItem.astro";
import FenceBlock from "../../components/FenceBlock.astro";
import Masthead from "../../components/Masthead.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import SourcesList from "../../components/SourcesList.astro";
import Base from "../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  citedPropertyValue,
  faqPageJsonLd,
  itemListJsonLd,
  maxVerifiedDate,
} from "../../lib/jsonld.ts";

const SITE = "https://mysecondcountry.com";

const gr = placeById("gr");
const pt = placeById("pt");
const es = placeById("es");
if (!gr || !pt || !es) throw new Error("Comparison needs gr, pt, es places");

// ---- Real cited values for the 6 dimensions ----
const costGr = gr.costOfLiving.priceLevelIndexEU27;
const costPt = pt.costOfLiving.priceLevelIndexEU27;
const costEs = es.costOfLiving.priceLevelIndexEU27;

const taxGr = gr.tax?.specialRegime;
const taxPt = pt.tax?.specialRegime;
const taxEs = es.tax?.specialRegime;
if (!taxGr || !taxPt || !taxEs) throw new Error("Missing tax.specialRegime data");

const visaGr = gr.residency?.digitalNomadVisa;
const visaPt = pt.residency?.digitalNomadVisa;
const visaEs = es.residency?.digitalNomadVisa;
if (!visaGr || !visaPt || !visaEs) throw new Error("Missing residency.digitalNomadVisa data");

const sunGr = gr.climate.averageAnnualSunHours;
const sunPt = pt.climate.averageAnnualSunHours;
const sunEs = es.climate.averageAnnualSunHours;
if (!sunGr || !sunPt || !sunEs) throw new Error("Missing climate.averageAnnualSunHours data");

const docGr = gr.healthcare?.physiciansPer1000;
const docPt = pt.healthcare?.physiciansPer1000;
const docEs = es.healthcare?.physiciansPer1000;
if (!docGr || !docPt || !docEs) throw new Error("Missing healthcare.physiciansPer1000 data");

const safeGr = gr.safety?.peaceIndexScore;
const safePt = pt.safety?.peaceIndexScore;
const safeEs = es.safety?.peaceIndexScore;
if (!safeGr || !safePt || !safeEs) throw new Error("Missing safety.peaceIndexScore data");

// ---- Source deduplication ----
// Build ordered list of unique sources by first appearance across all 6 dimensions.
// Order: cost (gr/pt/es share Eurostat), tax (gr, pt, es), visa (gr, pt, es),
// sun (gr/pt/es share Wikipedia pages), doc (gr/pt/es share Wikipedia), safety (shared GPI)
interface SourceEntry {
  url: string;
  name: string;
  verifiedDate: string;
}

const sourcesOrdered: SourceEntry[] = [];
const seenUrls = new Set<string>();

function addSource(url: string, name: string, verifiedDate: string): number {
  if (!seenUrls.has(url)) {
    seenUrls.add(url);
    sourcesOrdered.push({ url, name, verifiedDate });
  }
  const idx = sourcesOrdered.findIndex((s) => s.url === url);
  return idx + 1; // 1-based
}

// Cost (Eurostat shared)
const costSrcRef = addSource(costGr.sourceUrl, costGr.sourceName, costGr.verifiedDate);
// same URL for pt and es, so addSource returns same ref
addSource(costPt.sourceUrl, costPt.sourceName, costPt.verifiedDate);
addSource(costEs.sourceUrl, costEs.sourceName, costEs.verifiedDate);

// Tax (PwC, three distinct pages)
const taxSrcRefGr = addSource(taxGr.sourceUrl, taxGr.sourceName, taxGr.verifiedDate);
const taxSrcRefPt = addSource(taxPt.sourceUrl, taxPt.sourceName, taxPt.verifiedDate);
const taxSrcRefEs = addSource(taxEs.sourceUrl, taxEs.sourceName, taxEs.verifiedDate);

// Visa (three distinct sources)
const visaSrcRefGr = addSource(visaGr.sourceUrl, visaGr.sourceName, visaGr.verifiedDate);
const visaSrcRefPt = addSource(visaPt.sourceUrl, visaPt.sourceName, visaPt.verifiedDate);
const visaSrcRefEs = addSource(visaEs.sourceUrl, visaEs.sourceName, visaEs.verifiedDate);

// Sunshine (Wikipedia city pages -- may differ)
const sunSrcRefGr = addSource(sunGr.sourceUrl, sunGr.sourceName, sunGr.verifiedDate);
const sunSrcRefPt = addSource(sunPt.sourceUrl, sunPt.sourceName, sunPt.verifiedDate);
const sunSrcRefEs = addSource(sunEs.sourceUrl, sunEs.sourceName, sunEs.verifiedDate);

// Physicians (shared Wikipedia list)
const docSrcRefGr = addSource(docGr.sourceUrl, docGr.sourceName, docGr.verifiedDate);
const docSrcRefPt = addSource(docPt.sourceUrl, docPt.sourceName, docPt.verifiedDate);
const docSrcRefEs = addSource(docEs.sourceUrl, docEs.sourceName, docEs.verifiedDate);

// Safety (shared GPI)
const safeSrcRefGr = addSource(safeGr.sourceUrl, safeGr.sourceName, safeGr.verifiedDate);
const safeSrcRefPt = addSource(safePt.sourceUrl, safePt.sourceName, safePt.verifiedDate);
const safeSrcRefEs = addSource(safeEs.sourceUrl, safeEs.sourceName, safeEs.verifiedDate);

const title = "Greece vs Portugal vs Spain: a cited relocation comparison";
const description =
  "Cost, tax, visa, sunshine, healthcare, and safety for Greece, Portugal, and Spain, every figure linked to its source with a verified date and a confidence mark. Screening intelligence, not legal, tax, immigration, or financial guidance.";
const canonical = `${SITE}/compare/greece-portugal-spain`;

const COUNTRY_NAME = { gr: "Greece", pt: "Portugal", es: "Spain" } as const;
type CountryCode = keyof typeof COUNTRY_NAME;
type DisplayFormat = "currency" | "euIndex" | "integer" | "decimal2" | "decimal3";

const integerFormatter = new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 });
const euIndexFormatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 1,
  maximumFractionDigits: 1,
});
const decimal2Formatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});
const decimal3Formatter = new Intl.NumberFormat("en-US", {
  minimumFractionDigits: 3,
  maximumFractionDigits: 3,
});
const euroFormatter = new Intl.NumberFormat("en-US", {
  currency: "EUR",
  maximumFractionDigits: 0,
  style: "currency",
});

function numericCitedValue(cited: CitedValue): number | null {
  if (typeof cited.value === "number") return cited.value;
  if (typeof cited.value === "string") {
    const parsed = Number(cited.value.replace(/[^\d.-]/g, ""));
    return Number.isFinite(parsed) ? parsed : null;
  }
  return null;
}

function formatCitedValue(cited: CitedValue, format: DisplayFormat): string {
  const numericValue = numericCitedValue(cited);
  if (numericValue === null) return String(cited.value ?? "");

  switch (format) {
    case "currency":
      return euroFormatter.format(numericValue);
    case "euIndex":
      return euIndexFormatter.format(numericValue);
    case "integer":
      return integerFormatter.format(numericValue);
    case "decimal2":
      return decimal2Formatter.format(numericValue);
    case "decimal3":
      return decimal3Formatter.format(numericValue);
    default:
      return String(cited.value ?? "");
  }
}

function scenarioCell(cited: CitedValue, format: DisplayFormat, context: string) {
  return { cited, context, display: formatCitedValue(cited, format) };
}

function regimeRateCell(cited: CitedValue, displayRate: string, context: string) {
  return { cited, context, display: displayRate };
}

function matrixCell(
  cited: CitedValue,
  format: DisplayFormat,
  unit: string,
  subtext: string,
  sourceRef: number
) {
  return { cited, display: formatCitedValue(cited, format), sourceRef, subtext, unit };
}

function regimeRateMatrixCell(
  cited: CitedValue,
  displayRate: string,
  unit: string,
  subtext: string,
  sourceRef: number
) {
  return { cited, display: displayRate, sourceRef, subtext, unit };
}

const scenarioPanels: {
  id: "remote" | "taxes" | "retire" | "all";
  label: string;
  summary: string;
  rows: {
    label: string;
    note: string;
    cells: Record<CountryCode, { cited: CitedValue; display: string; context: string }>;
  }[];
}[] = [
  {
    id: "remote",
    label: "Work remotely",
    summary:
      "Start with visa income floor, cost, sunshine, and safety. The complete cited matrix remains below.",
    rows: [
      {
        label: "Remote-work visa income",
        note: "Minimum net monthly income for the digital-nomad or telework residence route.",
        cells: {
          gr: scenarioCell(visaGr, "currency", "net monthly floor"),
          pt: scenarioCell(visaPt, "currency", "monthly floor"),
          es: scenarioCell(visaEs, "currency", "net monthly floor"),
        },
      },
      {
        label: "Cost of living",
        note: "Eurostat price-level index for actual individual consumption, EU27 equals 100.",
        cells: {
          gr: scenarioCell(costGr, "euIndex", "EU27=100"),
          pt: scenarioCell(costPt, "euIndex", "EU27=100"),
          es: scenarioCell(costEs, "euIndex", "EU27=100"),
        },
      },
      {
        label: "Sunshine",
        note: "Capital-city sunshine hours, not a national average.",
        cells: {
          gr: scenarioCell(sunGr, "integer", "hours per year"),
          pt: scenarioCell(sunPt, "integer", "hours per year"),
          es: scenarioCell(sunEs, "integer", "hours per year"),
        },
      },
      {
        label: "Safety",
        note: "Global Peace Index score. Lower score means more peaceful in that index.",
        cells: {
          gr: scenarioCell(safeGr, "decimal3", "GPI score"),
          pt: scenarioCell(safePt, "decimal3", "GPI score"),
          es: scenarioCell(safeEs, "decimal3", "GPI score"),
        },
      },
    ],
  },
  {
    id: "taxes",
    label: "Compare tax exposure",
    summary:
      "Start with the published regime rate and the visa income floor. These are not comparable legal routes.",
    rows: [
      {
        label: "Published regime rate",
        note: "Headline rate only. Eligibility, income type, and duration differ by country.",
        cells: {
          gr: regimeRateCell(taxGr, "7%", "foreign-pension regime"),
          pt: regimeRateCell(taxPt, "20%", "IFICI"),
          es: regimeRateCell(taxEs, "24%", "Beckham regime"),
        },
      },
      {
        label: "Remote-work visa income",
        note: "Income-floor rules can matter before any tax route is relevant.",
        cells: {
          gr: scenarioCell(visaGr, "currency", "net monthly floor"),
          pt: scenarioCell(visaPt, "currency", "monthly floor"),
          es: scenarioCell(visaEs, "currency", "net monthly floor"),
        },
      },
    ],
  },
  {
    id: "retire",
    label: "Retirement screen",
    summary:
      "Start with cost, healthcare capacity, safety, sunshine, and the published pension-tax route where available.",
    rows: [
      {
        label: "Cost of living",
        note: "Whole-country price-level index, useful as a first screen before local checks.",
        cells: {
          gr: scenarioCell(costGr, "euIndex", "EU27=100"),
          pt: scenarioCell(costPt, "euIndex", "EU27=100"),
          es: scenarioCell(costEs, "euIndex", "EU27=100"),
        },
      },
      {
        label: "Physicians per 1,000",
        note: "Licensed medical doctors per 1,000 people. It does not measure appointment access.",
        cells: {
          gr: scenarioCell(docGr, "decimal2", "per 1,000"),
          pt: scenarioCell(docPt, "decimal2", "per 1,000"),
          es: scenarioCell(docEs, "decimal2", "per 1,000"),
        },
      },
      {
        label: "Safety",
        note: "Global Peace Index score. Lower score means more peaceful in that index.",
        cells: {
          gr: scenarioCell(safeGr, "decimal3", "GPI score"),
          pt: scenarioCell(safePt, "decimal3", "GPI score"),
          es: scenarioCell(safeEs, "decimal3", "GPI score"),
        },
      },
      {
        label: "Published regime rate",
        note: "Headline rate only. Pension treatment and eligibility need official-source review.",
        cells: {
          gr: regimeRateCell(taxGr, "7%", "foreign-pension regime"),
          pt: regimeRateCell(taxPt, "20%", "IFICI"),
          es: regimeRateCell(taxEs, "24%", "Beckham regime"),
        },
      },
    ],
  },
  {
    id: "all",
    label: "All cited dimensions",
    summary:
      "Use this when you are ready for the full matrix. Each cell keeps source, verified date, confidence, and granularity close to the value.",
    rows: [],
  },
];

const countryOrder = ["gr", "pt", "es"] as const;

const matrixRows: {
  id: string;
  scenarios: string;
  label: string;
  description: string;
  note: string;
  cells: Record<
    CountryCode,
    {
      cited: CitedValue;
      display: string;
      unit?: string;
      subtext: string;
      sourceRef: number;
    }
  >;
}[] = [
  {
    id: "cost",
    scenarios: "remote retire",
    label: "Cost of living",
    description:
      "Eurostat price level index for actual consumption. 100 is the EU average; lower is cheaper.",
    note: "Lowest shown in this dataset: Portugal.",
    cells: {
      gr: matrixCell(costGr, "euIndex", "EU27=100", "Whole-country index", costSrcRef),
      pt: matrixCell(costPt, "euIndex", "EU27=100", "Whole-country index", costSrcRef),
      es: matrixCell(costEs, "euIndex", "EU27=100", "Whole-country index", costSrcRef),
    },
  },
  {
    id: "tax",
    scenarios: "taxes retire",
    label: "Published regime tax rate",
    description:
      "Headline rate of the published expat regime used in this comparison. These are different regimes with different eligibility.",
    note: "Lowest shown in this dataset: Greece.",
    cells: {
      gr: regimeRateMatrixCell(taxGr, "7%", "flat", "Foreign-pension regime, article 5B", taxSrcRefGr),
      pt: regimeRateMatrixCell(taxPt, "20%", "flat", "IFICI, the NHR successor", taxSrcRefPt),
      es: regimeRateMatrixCell(taxEs, "24%", "flat", "Beckham regime, first six years", taxSrcRefEs),
    },
  },
  {
    id: "visa",
    scenarios: "remote taxes",
    label: "Remote-work visa income",
    description:
      "Minimum net monthly income for the digital-nomad or telework residence visa. Lower is more accessible.",
    note: "Lowest shown in this dataset: Spain.",
    cells: {
      gr: matrixCell(visaGr, "currency", "/mo min", "Net income floor, law 5038/2023", visaSrcRefGr),
      pt: matrixCell(visaPt, "currency", "/mo min", "Four times the minimum wage (D8)", visaSrcRefPt),
      es: matrixCell(visaEs, "currency", "/mo min", "200% of the minimum wage (telework visa)", visaSrcRefEs),
    },
  },
  {
    id: "sunshine",
    scenarios: "remote retire",
    label: "Sunshine",
    description:
      "Mean annual sunshine hours at the capital. A single-source city figure, not a national average.",
    note: "Highest shown in this dataset: Lisbon.",
    cells: {
      gr: matrixCell(sunGr, "integer", "hrs/yr", "Athens (Elliniko)", sunSrcRefGr),
      pt: matrixCell(sunPt, "integer", "hrs/yr", "Lisbon", sunSrcRefPt),
      es: matrixCell(sunEs, "integer", "hrs/yr", "Madrid", sunSrcRefEs),
    },
  },
  {
    id: "physicians",
    scenarios: "retire",
    label: "Physicians per 1,000",
    description:
      "Licensed medical doctors per 1,000 people (WHO 2021). Counts licensed, not only practising, doctors.",
    note: "Highest shown in this dataset: Greece.",
    cells: {
      gr: matrixCell(docGr, "decimal2", "per 1,000", "WHO 2021", docSrcRefGr),
      pt: matrixCell(docPt, "decimal2", "per 1,000", "WHO 2021", docSrcRefPt),
      es: matrixCell(docEs, "decimal2", "per 1,000", "WHO 2021", docSrcRefEs),
    },
  },
  {
    id: "safety",
    scenarios: "remote retire",
    label: "Safety (Global Peace Index)",
    description: "Global Peace Index 2024 score. Lower is more peaceful.",
    note: "Lowest score shown in this dataset: Portugal.",
    cells: {
      gr: matrixCell(safeGr, "decimal3", "GPI", "Rank 40 of 163", safeSrcRefGr),
      pt: matrixCell(safePt, "decimal3", "GPI", "Rank 7 of 163", safeSrcRefPt),
      es: matrixCell(safeEs, "decimal3", "GPI", "Rank 23 of 163", safeSrcRefEs),
    },
  },
];

// Every cited cell behind the comparison grid, enriched into a machine PropertyValue.
const measuredDims: {
  label: string;
  unit?: string;
  cells: Record<"gr" | "pt" | "es", CitedValue>;
}[] = [
  {
    label: "cost of living, price level index",
    unit: "EU27=100",
    cells: { gr: costGr, pt: costPt, es: costEs },
  },
  { label: "published expat tax regime", cells: { gr: taxGr, pt: taxPt, es: taxEs } },
  {
    label: "remote-work visa minimum income",
    unit: "EUR per month",
    cells: { gr: visaGr, pt: visaPt, es: visaEs },
  },
  {
    label: "average annual sunshine",
    unit: "hours per year",
    cells: { gr: sunGr, pt: sunPt, es: sunEs },
  },
  {
    label: "physicians per 1,000 people",
    unit: "per 1,000",
    cells: { gr: docGr, pt: docPt, es: docEs },
  },
  { label: "Global Peace Index score", unit: "GPI", cells: { gr: safeGr, pt: safePt, es: safeEs } },
];

const allCells = measuredDims.flatMap((d) => [d.cells.gr, d.cells.pt, d.cells.es]);
const maxDate = maxVerifiedDate(allCells);
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: sourcesOrdered.length,
});

const variableMeasured = measuredDims.flatMap((d) =>
  (["gr", "pt", "es"] as const).map((c) =>
    citedPropertyValue({
      name: `${COUNTRY_NAME[c]} ${d.label}`,
      cited: d.cells[c],
      unitText: d.unit,
      id: `${canonical}#${c}-${d.label.replace(/[^a-z0-9]+/gi, "-")}`,
    }),
  ),
);

const breadcrumbItems = [
  { name: "Home", href: "/" },
  { name: "Greece vs Portugal vs Spain", href: "/compare/greece-portugal-spain" },
];

// Scenario summaries as cited FAQ pairs. Each question is a visible <h3> mirrored into
// FAQPage JSON-LD (assert-faq-jsonld checks the match).
const faqs = [
  {
    question: "Which has the lowest special tax rate: Greece, Portugal, or Spain?",
    answer:
      "Greece, at a flat 7% on foreign-source pension income (article 5B), against Portugal's 20% (IFICI) and Spain's 24% (Beckham). They are different regimes with different eligibility (PwC Worldwide Tax Summaries, verified 2026-06-24). Check the official source and a qualified tax professional before acting.",
  },
  {
    question: "Which has the lowest digital nomad visa income requirement?",
    answer:
      "Spain, at a net €2,849 a month (200% of the minimum wage), against Greece at €3,500 and Portugal at €3,680 (national immigration sources, verified June 2026).",
  },
  {
    question: "Which is the most peaceful and the cheapest of the three?",
    answer:
      "Portugal on both: the lowest Eurostat price level of the three and the lowest Global Peace Index rank (7 of 163), against Greece (rank 40) and Spain (rank 23) (Eurostat and Institute for Economics and Peace, verified 2026-06-24).",
  },
];

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: title,
    description,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "@id": `${canonical}#dataset`,
    name: title,
    description,
    url: canonical,
    isAccessibleForFree: true,
    creator: { "@type": "Organization", name: "My Second Country", url: SITE },
    license: SITE,
    isPartOf: { "@type": "DataCatalog", name: "My Second Country relocation dataset", url: SITE },
    dateModified: maxDate,
    about: [
      { "@type": "Place", name: "Greece", url: `${SITE}/places/greece` },
      { "@type": "Place", name: "Portugal", url: `${SITE}/places/portugal` },
      { "@type": "Place", name: "Spain", url: `${SITE}/places/spain` },
    ],
    variableMeasured,
  },
  faqPageJsonLd(faqs),
  itemListJsonLd({
    url: canonical,
    items: [
      { position: 1, name: "Greece", url: `${SITE}/places/greece` },
      { position: 2, name: "Portugal", url: `${SITE}/places/portugal` },
      { position: 3, name: "Spain", url: `${SITE}/places/spain` },
    ],
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd} fullBleed={true}>

  <!-- Nav extra: country pills (faded in by JS after hero scrolls) -->
  <Fragment slot="nav-extra">
    <div class="nav-pills" id="navPills" aria-label="Countries compared">
      <span class="nav-pill nav-pill--gr">🇬🇷 Greece</span>
      <span class="nav-pill nav-pill--pt">🇵🇹 Portugal</span>
      <span class="nav-pill nav-pill--es">🇪🇸 Spain</span>
    </div>
  </Fragment>

  <div data-page="comparison" data-compare="greece-portugal-spain">

    <!-- ── MASTHEAD ──────────────────────────────────────────────────────── -->
    <Masthead
      variant="compare"
      id="heroSection"
      title="Greece vs Portugal vs Spain"
      dateline={dateline}
      standfirst="Six measures, every figure sourced, dated, and confidence rated. The page compares evidence without selecting a country."
    >
      <Fragment slot="title">Greece <em>vs</em> Portugal <em>vs</em> Spain</Fragment>

      <Fragment slot="media">
        {/* TODO: production needs licensed, optimised, locally hosted images
            (responsive srcset, modern format, e.g. AVIF/WebP). Replace these
            Unsplash hotlinks before launching. */}
        <div class="masthead-photos">
          <!-- Greece -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?w=900&h=700&fit=crop&auto=format"
              alt="Acropolis above Athens at golden hour"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--gr">Greece</p>
              <p class="masthead-place">Athens on the Aegean</p>
            </div>
          </div>

          <!-- Portugal -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1762144062643-699966b2f7f9?w=900&h=700&fit=crop&auto=format"
              alt="Terracotta rooftops and the Tagus river, Lisbon"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--pt">Portugal</p>
              <p class="masthead-place">Lisbon on the Atlantic</p>
            </div>
          </div>

          <!-- Spain -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1764246195415-6e83157c2c74?w=900&h=700&fit=crop&auto=format"
              alt="Ornate arched courtyard in Seville"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--es">Spain</p>
              <p class="masthead-place">Seville in the south</p>
            </div>
          </div>
        </div>
      </Fragment>
    </Masthead>

    <!-- ── FENCE (above filters, above first data claim) ───────────────── -->
    <div class="fence-wrap">
      <FenceBlock hasLegalClaims={true} />
    </div>

    <!-- ── SCENARIO FILTERS ──────────────────────────────────────────────── -->
    <div class="tabs-section">
      <div class="tabs-list" role="group" aria-label="Filter by scenario">
        <button class="tab-btn active" type="button" aria-pressed="true" data-filter="remote">Work remotely</button>
        <button class="tab-btn" type="button" aria-pressed="false" data-filter="taxes">Compare tax exposure</button>
        <button class="tab-btn" type="button" aria-pressed="false" data-filter="retire">Retirement screen</button>
        <button class="tab-btn" type="button" aria-pressed="false" data-filter="all">All cited dimensions</button>
      </div>
    </div>

    <!-- ── SCENARIO FIRST: source-adjacent values before the full matrix ───── -->
    <section class="scenario-first" aria-labelledby="scenario-first-heading" aria-live="polite">
      <div class="scenario-first__head">
        <p class="scenario-kicker">Start with a concern</p>
        <h2 id="scenario-first-heading">A smaller first read before the full table.</h2>
        <p>
