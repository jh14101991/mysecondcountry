  <script>
    /* ── Tab switching ───────────────────────────────────────────────────── */
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = btn.dataset.tab ?? "all";

        // Active state
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach((b) => {
          const isActive = b.dataset.tab === tab;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        // "What the data shows" block: hidden entirely on "all", else show matching note
        const showsWrap = document.querySelector<HTMLElement>(".shows-wrap");
        if (showsWrap) showsWrap.hidden = tab === "all";
        document.querySelectorAll<HTMLElement>(".shows-text").forEach((el) => {
          el.hidden = !(tab !== "all" && el.dataset.shows === tab);
        });

        // Metric rows: show/hide by data-scenarios
        document.querySelectorAll<HTMLElement>(".metric-row").forEach((row) => {
          if (tab === "all") {
            row.hidden = false;
          } else {
            const scenarios = (row.dataset.scenarios ?? "").split(" ");
            row.hidden = !scenarios.includes(tab);
          }
        });

        // Small multiples: show/hide by data-scenarios
        document.querySelectorAll<HTMLElement>(".multiple-chart").forEach((chart) => {
          if (tab === "all") {
            chart.hidden = false;
          } else {
            const scenarios = (chart.dataset.scenarios ?? "").split(" ");
            chart.hidden = !scenarios.includes(tab);
          }
        });
      });
    });

    /* ── Bar animation (IntersectionObserver) ───────────────────────────── */
    function attachBarObservers(): void {
      const fills = document.querySelectorAll<HTMLElement>(".bar-fill");
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const el = e.target as HTMLElement;
              const score = el.dataset.score ?? "40";
              el.style.width = score + "%";
              obs.unobserve(el);
            }
          });
        },
        { rootMargin: "-60px 0px" }
      );
      fills.forEach((f) => obs.observe(f));
    }
    attachBarObservers();

    /* ── Column hover dimming ────────────────────────────────────────────── */
    function attachHoverListeners(): void {
      const rows = document.querySelectorAll<HTMLElement>(".metric-row");
      rows.forEach((row) => {
        const cells = row.querySelectorAll<HTMLElement>(".country-cell");
        cells.forEach((cell) => {
          const country = cell.dataset.country;
          cell.addEventListener("mouseenter", () => setHover(country ?? null));
          cell.addEventListener("mouseleave", () => setHover(null));
        });
      });
    }

    function setHover(country: string | null): void {
      const allCells = document.querySelectorAll<HTMLElement>(".country-cell");
      allCells.forEach((cell) => {
        if (country === null) {
          cell.style.opacity = "1";
        } else {
          cell.style.opacity = cell.dataset.country === country ? "1" : "0.28";
        }
      });
    }
    attachHoverListeners();

    /* ── Nav pills fade in after hero scrolls past ───────────────────────── */
    const heroEl = document.getElementById("heroSection");
    const navPills = document.getElementById("navPills");
    if (heroEl && navPills) {
      const heroObs = new IntersectionObserver(([e]) => {
        if (!e?.isIntersecting) {
          navPills.classList.add("visible");
        } else {
          navPills.classList.remove("visible");
        }
      }, { threshold: 0 });
      heroObs.observe(heroEl);
    }

  </script>

