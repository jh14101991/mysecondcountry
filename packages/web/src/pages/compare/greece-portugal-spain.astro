---
import type { CitedValue } from "@where/data";
import { placeById } from "@where/data";
import AtAGlance from "../../components/AtAGlance.astro";
import ComparisonCell from "../../components/ComparisonCell.astro";
import FaqItem from "../../components/FaqItem.astro";
import FenceBlock from "../../components/FenceBlock.astro";
import Masthead from "../../components/Masthead.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import SourcesList from "../../components/SourcesList.astro";
import Base from "../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  citedPropertyValue,
  faqPageJsonLd,
  itemListJsonLd,
  maxVerifiedDate,
} from "../../lib/jsonld.ts";

const SITE = "https://mysecondcountry.com";

const gr = placeById("gr");
const pt = placeById("pt");
const es = placeById("es");
if (!gr || !pt || !es) throw new Error("Comparison needs gr, pt, es places");

// ---- Real cited values for the 6 dimensions ----
const costGr = gr.costOfLiving.priceLevelIndexEU27;
const costPt = pt.costOfLiving.priceLevelIndexEU27;
const costEs = es.costOfLiving.priceLevelIndexEU27;

const taxGr = gr.tax?.specialRegime;
const taxPt = pt.tax?.specialRegime;
const taxEs = es.tax?.specialRegime;
if (!taxGr || !taxPt || !taxEs) throw new Error("Missing tax.specialRegime data");

const visaGr = gr.residency?.digitalNomadVisa;
const visaPt = pt.residency?.digitalNomadVisa;
const visaEs = es.residency?.digitalNomadVisa;
if (!visaGr || !visaPt || !visaEs) throw new Error("Missing residency.digitalNomadVisa data");

const sunGr = gr.climate.averageAnnualSunHours;
const sunPt = pt.climate.averageAnnualSunHours;
const sunEs = es.climate.averageAnnualSunHours;
if (!sunGr || !sunPt || !sunEs) throw new Error("Missing climate.averageAnnualSunHours data");

const docGr = gr.healthcare?.physiciansPer1000;
const docPt = pt.healthcare?.physiciansPer1000;
const docEs = es.healthcare?.physiciansPer1000;
if (!docGr || !docPt || !docEs) throw new Error("Missing healthcare.physiciansPer1000 data");

const safeGr = gr.safety?.peaceIndexScore;
const safePt = pt.safety?.peaceIndexScore;
const safeEs = es.safety?.peaceIndexScore;
if (!safeGr || !safePt || !safeEs) throw new Error("Missing safety.peaceIndexScore data");

// ---- Source deduplication ----
// Build ordered list of unique sources by first appearance across all 6 dimensions.
// Order: cost (gr/pt/es share Eurostat), tax (gr, pt, es), visa (gr, pt, es),
// sun (gr/pt/es share Wikipedia pages), doc (gr/pt/es share Wikipedia), safety (shared GPI)
interface SourceEntry {
  url: string;
  name: string;
  verifiedDate: string;
}

const sourcesOrdered: SourceEntry[] = [];
const seenUrls = new Set<string>();

function addSource(url: string, name: string, verifiedDate: string): number {
  if (!seenUrls.has(url)) {
    seenUrls.add(url);
    sourcesOrdered.push({ url, name, verifiedDate });
  }
  const idx = sourcesOrdered.findIndex((s) => s.url === url);
  return idx + 1; // 1-based
}

// Cost (Eurostat shared)
const costSrcRef = addSource(costGr.sourceUrl, costGr.sourceName, costGr.verifiedDate);
// same URL for pt and es, so addSource returns same ref
addSource(costPt.sourceUrl, costPt.sourceName, costPt.verifiedDate);
addSource(costEs.sourceUrl, costEs.sourceName, costEs.verifiedDate);

// Tax (PwC, three distinct pages)
const taxSrcRefGr = addSource(taxGr.sourceUrl, taxGr.sourceName, taxGr.verifiedDate);
const taxSrcRefPt = addSource(taxPt.sourceUrl, taxPt.sourceName, taxPt.verifiedDate);
const taxSrcRefEs = addSource(taxEs.sourceUrl, taxEs.sourceName, taxEs.verifiedDate);

// Visa (three distinct sources)
const visaSrcRefGr = addSource(visaGr.sourceUrl, visaGr.sourceName, visaGr.verifiedDate);
const visaSrcRefPt = addSource(visaPt.sourceUrl, visaPt.sourceName, visaPt.verifiedDate);
const visaSrcRefEs = addSource(visaEs.sourceUrl, visaEs.sourceName, visaEs.verifiedDate);

// Sunshine (Wikipedia city pages -- may differ)
const sunSrcRefGr = addSource(sunGr.sourceUrl, sunGr.sourceName, sunGr.verifiedDate);
const sunSrcRefPt = addSource(sunPt.sourceUrl, sunPt.sourceName, sunPt.verifiedDate);
const sunSrcRefEs = addSource(sunEs.sourceUrl, sunEs.sourceName, sunEs.verifiedDate);

// Physicians (shared Wikipedia list)
const docSrcRefGr = addSource(docGr.sourceUrl, docGr.sourceName, docGr.verifiedDate);
const docSrcRefPt = addSource(docPt.sourceUrl, docPt.sourceName, docPt.verifiedDate);
const docSrcRefEs = addSource(docEs.sourceUrl, docEs.sourceName, docEs.verifiedDate);

// Safety (shared GPI)
const safeSrcRefGr = addSource(safeGr.sourceUrl, safeGr.sourceName, safeGr.verifiedDate);
const safeSrcRefPt = addSource(safePt.sourceUrl, safePt.sourceName, safePt.verifiedDate);
const safeSrcRefEs = addSource(safeEs.sourceUrl, safeEs.sourceName, safeEs.verifiedDate);

// ---- Score computation for ComparisonCell bars ----
// normalize: t = (v - min)/(max - min); if dir=min flip t; score = Math.round(40 + 60*t)
function radarScore(v: number, min: number, max: number, dir: "min" | "max"): number {
  if (max === min) return 70;
  let t = (v - min) / (max - min);
  if (dir === "min") t = 1 - t;
  return Math.round(40 + 60 * t);
}

// Cost scores (dir=min)
const costScoreGr = radarScore(costGr.value as number, 86.6, 91.6, "min");
const costScorePt = radarScore(costPt.value as number, 86.6, 91.6, "min");
const costScoreEs = radarScore(costEs.value as number, 86.6, 91.6, "min");

// Tax scores (dir=min)
const taxScoreGr = radarScore(7, 7, 24, "min");
const taxScorePt = radarScore(20, 7, 24, "min");
const taxScoreEs = radarScore(24, 7, 24, "min");

// Visa values and scores (dir=min)
const visaVGr = visaGr.value as number;
const visaVPt = visaPt.value as number;
const visaVEs = visaEs.value as number;
const visaMin = Math.min(visaVGr, visaVPt, visaVEs);
const visaMax = Math.max(visaVGr, visaVPt, visaVEs);
const visaScoreGr = radarScore(visaVGr, visaMin, visaMax, "min");
const visaScorePt = radarScore(visaVPt, visaMin, visaMax, "min");
const visaScoreEs = radarScore(visaVEs, visaMin, visaMax, "min");

// Sunshine values and scores (dir=max)
const sunVGr = sunGr.value as number;
const sunVPt = sunPt.value as number;
const sunVEs = sunEs.value as number;
const sunMin = Math.min(sunVGr, sunVPt, sunVEs);
const sunMax = Math.max(sunVGr, sunVPt, sunVEs);
const sunScoreGr = radarScore(sunVGr, sunMin, sunMax, "max");
const sunScorePt = radarScore(sunVPt, sunMin, sunMax, "max");
const sunScoreEs = radarScore(sunVEs, sunMin, sunMax, "max");

// Physician values and scores (dir=max)
const docVGr = docGr.value as number;
const docVPt = docPt.value as number;
const docVEs = docEs.value as number;
const docMin = Math.min(docVGr, docVPt, docVEs);
const docMax = Math.max(docVGr, docVPt, docVEs);
const docScoreGr = radarScore(docVGr, docMin, docMax, "max");
const docScorePt = radarScore(docVPt, docMin, docMax, "max");
const docScoreEs = radarScore(docVEs, docMin, docMax, "max");

// Safety values and scores (dir=min)
const safeVGr = safeGr.value as number;
const safeVPt = safePt.value as number;
const safeVEs = safeEs.value as number;
const safeMin = Math.min(safeVGr, safeVPt, safeVEs);
const safeMax = Math.max(safeVGr, safeVPt, safeVEs);
const safeScoreGr = radarScore(safeVGr, safeMin, safeMax, "min");
const safeScorePt = radarScore(safeVPt, safeMin, safeMax, "min");
const safeScoreEs = radarScore(safeVEs, safeMin, safeMax, "min");

// ---- Leader computations ----
// Each dimension: the country with the best value leads
// cost: min leader = PT (86.6)
const costLeader: "gr" | "pt" | "es" = "pt";
// tax: min leader = GR (7%)
const taxLeader: "gr" | "pt" | "es" = "gr";
// visa: min leader = ES (2849)
const visaLeader: "gr" | "pt" | "es" = "es";
// sunshine: max leader = PT (2874.9)
const sunLeader: "gr" | "pt" | "es" = "pt";
// physicians: max leader = GR (6.37)
const docLeader: "gr" | "pt" | "es" = "gr";
// safety: min leader = PT (1.372)
const safeLeader: "gr" | "pt" | "es" = "pt";

// ---- Small multiples: dot position computation ----
function dotPos(raw: number, lo: number, span: number): number {
  return Math.round(Math.max(0, Math.min(100, ((raw - lo) / span) * 100)));
}
function padRange(values: number[]): { lo: number; span: number } {
  const mn = Math.min(...values);
  const mx = Math.max(...values);
  const pad = mx === mn ? 5 : (mx - mn) * 0.18;
  return { lo: mn - pad, span: mx - mn + pad * 2 };
}

const costRaws = [costGr.value as number, costPt.value as number, costEs.value as number];
const taxRaws = [7, 20, 24];
const visaRaws = [visaVGr, visaVPt, visaVEs];
const sunRaws = [sunVGr, sunVPt, sunVEs];
const docRaws = [docVGr, docVPt, docVEs];
const safeRaws = [safeVGr, safeVPt, safeVEs];

const costRange = padRange(costRaws);
const taxRange = padRange(taxRaws);
const visaRange = padRange(visaRaws);
const sunRange = padRange(sunRaws);
const docRange = padRange(docRaws);
const safeRange = padRange(safeRaws);

// Dot positions (0=left, 100=right, left=worse, right=better for display)
// For "lower is better" metrics, flip so leader is on the right
function flipPos(pos: number): number {
  return 100 - pos;
}

const multiples = [
  {
    label: "Cost",
    caption: "lower is better",
    scenarios: "remote retire",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: flipPos(dotPos(costRaws[0] ?? 0, costRange.lo, costRange.span)),
        isLeader: costLeader === "gr",
        value: `${costRaws[0]}`,
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: flipPos(dotPos(costRaws[1] ?? 0, costRange.lo, costRange.span)),
        isLeader: costLeader === "pt",
        value: `${costRaws[1]}`,
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: flipPos(dotPos(costRaws[2] ?? 0, costRange.lo, costRange.span)),
        isLeader: costLeader === "es",
        value: `${costRaws[2]}`,
      },
    ],
  },
  {
    label: "Tax regime",
    caption: "lower is better",
    scenarios: "taxes retire",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: flipPos(dotPos(taxRaws[0] ?? 0, taxRange.lo, taxRange.span)),
        isLeader: taxLeader === "gr",
        value: "7%",
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: flipPos(dotPos(taxRaws[1] ?? 0, taxRange.lo, taxRange.span)),
        isLeader: taxLeader === "pt",
        value: "20%",
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: flipPos(dotPos(taxRaws[2] ?? 0, taxRange.lo, taxRange.span)),
        isLeader: taxLeader === "es",
        value: "24%",
      },
    ],
  },
  {
    label: "Visa income floor",
    caption: "lower is better",
    scenarios: "remote taxes",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: flipPos(dotPos(visaRaws[0] ?? 0, visaRange.lo, visaRange.span)),
        isLeader: visaLeader === "gr",
        value: "€3,500",
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: flipPos(dotPos(visaRaws[1] ?? 0, visaRange.lo, visaRange.span)),
        isLeader: visaLeader === "pt",
        value: "€3,680",
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: flipPos(dotPos(visaRaws[2] ?? 0, visaRange.lo, visaRange.span)),
        isLeader: visaLeader === "es",
        value: "€2,849",
      },
    ],
  },
  {
    label: "Sunshine",
    caption: "higher is better",
    scenarios: "remote retire",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: dotPos(sunRaws[0] ?? 0, sunRange.lo, sunRange.span),
        isLeader: sunLeader === "gr",
        value: "2,773",
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: dotPos(sunRaws[1] ?? 0, sunRange.lo, sunRange.span),
        isLeader: sunLeader === "pt",
        value: "2,875",
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: dotPos(sunRaws[2] ?? 0, sunRange.lo, sunRange.span),
        isLeader: sunLeader === "es",
        value: "2,744",
      },
    ],
  },
  {
    label: "Physicians",
    caption: "higher is better",
    scenarios: "retire",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: dotPos(docRaws[0] ?? 0, docRange.lo, docRange.span),
        isLeader: docLeader === "gr",
        value: "6.37",
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: dotPos(docRaws[1] ?? 0, docRange.lo, docRange.span),
        isLeader: docLeader === "pt",
        value: "5.77",
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: dotPos(docRaws[2] ?? 0, docRange.lo, docRange.span),
        isLeader: docLeader === "es",
        value: "4.48",
      },
    ],
  },
  {
    label: "Safety (GPI)",
    caption: "lower is better",
    scenarios: "remote retire",
    dots: [
      {
        country: "gr" as const,
        tag: "GR",
        pos: flipPos(dotPos(safeRaws[0] ?? 0, safeRange.lo, safeRange.span)),
        isLeader: safeLeader === "gr",
        value: "1.793",
      },
      {
        country: "pt" as const,
        tag: "PT",
        pos: flipPos(dotPos(safeRaws[1] ?? 0, safeRange.lo, safeRange.span)),
        isLeader: safeLeader === "pt",
        value: "1.372",
      },
      {
        country: "es" as const,
        tag: "ES",
        pos: flipPos(dotPos(safeRaws[2] ?? 0, safeRange.lo, safeRange.span)),
        isLeader: safeLeader === "es",
        value: "1.597",
      },
    ],
  },
];

const title = "Greece vs Portugal vs Spain: a cited relocation comparison";
const description =
  "Cost, tax, visa, sunshine, healthcare, and safety for Greece, Portugal, and Spain, every figure linked to its source with a verified date and a confidence mark. Screening intelligence, not advice.";
const canonical = `${SITE}/compare/greece-portugal-spain`;

const COUNTRY_NAME = { gr: "Greece", pt: "Portugal", es: "Spain" } as const;

// Every cited cell behind the comparison grid, enriched into a machine PropertyValue.
const measuredDims: {
  label: string;
  unit?: string;
  cells: Record<"gr" | "pt" | "es", CitedValue>;
}[] = [
  {
    label: "cost of living, price level index",
    unit: "EU27=100",
    cells: { gr: costGr, pt: costPt, es: costEs },
  },
  { label: "best published expat tax regime", cells: { gr: taxGr, pt: taxPt, es: taxEs } },
  {
    label: "remote-work visa minimum income",
    unit: "EUR per month",
    cells: { gr: visaGr, pt: visaPt, es: visaEs },
  },
  {
    label: "average annual sunshine",
    unit: "hours per year",
    cells: { gr: sunGr, pt: sunPt, es: sunEs },
  },
  {
    label: "physicians per 1,000 people",
    unit: "per 1,000",
    cells: { gr: docGr, pt: docPt, es: docEs },
  },
  { label: "Global Peace Index score", unit: "GPI", cells: { gr: safeGr, pt: safePt, es: safeEs } },
];

const allCells = measuredDims.flatMap((d) => [d.cells.gr, d.cells.pt, d.cells.es]);
const maxDate = maxVerifiedDate(allCells);
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: sourcesOrdered.length,
});

const variableMeasured = measuredDims.flatMap((d) =>
  (["gr", "pt", "es"] as const).map((c) =>
    citedPropertyValue({
      name: `${COUNTRY_NAME[c]} ${d.label}`,
      cited: d.cells[c],
      unitText: d.unit,
      id: `${canonical}#${c}-${d.label.replace(/[^a-z0-9]+/gi, "-")}`,
    }),
  ),
);

// Leader strip cells, factual not advisory. Mirrors the grid's row leaders.
const leaders = [
  { label: "Cost", stat: "86.6 index", country: "pt" as const, countryLabel: "🇵🇹 Portugal" },
  { label: "Tax regime", stat: "7% flat", country: "gr" as const, countryLabel: "🇬🇷 Greece" },
  { label: "Visa floor", stat: "€2,849/mo", country: "es" as const, countryLabel: "🇪🇸 Spain" },
  { label: "Sunshine", stat: "2,875 hrs", country: "pt" as const, countryLabel: "🇵🇹 Portugal" },
  { label: "Doctors", stat: "6.37/1,000", country: "gr" as const, countryLabel: "🇬🇷 Greece" },
  { label: "Safety", stat: "GPI rank 7", country: "pt" as const, countryLabel: "🇵🇹 Portugal" },
];

const breadcrumbItems = [
  { name: "Home", href: "/" },
  { name: "Greece vs Portugal vs Spain", href: "/compare/greece-portugal-spain" },
];

// Scenario summaries as cited FAQ pairs. Each question is a visible <h3> mirrored into
// FAQPage JSON-LD (assert-faq-jsonld checks the match).
const faqs = [
  {
    question: "Which has the lowest special tax rate: Greece, Portugal, or Spain?",
    answer:
      "Greece, at a flat 7% on foreign-source pension income (article 5B), against Portugal's 20% (IFICI) and Spain's 24% (Beckham). They are different regimes with different eligibility (PwC Worldwide Tax Summaries, verified 2026-06-24). Confirm yours with a licensed tax adviser.",
  },
  {
    question: "Which has the lowest digital nomad visa income requirement?",
    answer:
      "Spain, at a net €2,849 a month (200% of the minimum wage), against Greece at €3,500 and Portugal at €3,680 (national immigration sources, verified June 2026).",
  },
  {
    question: "Which is the most peaceful and the cheapest of the three?",
    answer:
      "Portugal on both: the lowest Eurostat price level of the three and the best Global Peace Index rank (7 of 163), against Greece (rank 40) and Spain (rank 23) (Eurostat and Institute for Economics and Peace, verified 2026-06-24).",
  },
];

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: title,
    description,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "@id": `${canonical}#dataset`,
    name: title,
    description,
    url: canonical,
    isAccessibleForFree: true,
    creator: { "@type": "Organization", name: "My Second Country", url: SITE },
    license: SITE,
    isPartOf: { "@type": "DataCatalog", name: "My Second Country relocation dataset", url: SITE },
    dateModified: maxDate,
    about: [
      { "@type": "Place", name: "Greece", url: `${SITE}/places/greece` },
      { "@type": "Place", name: "Portugal", url: `${SITE}/places/portugal` },
      { "@type": "Place", name: "Spain", url: `${SITE}/places/spain` },
    ],
    variableMeasured,
  },
  faqPageJsonLd(faqs),
  itemListJsonLd({
    url: canonical,
    items: [
      { position: 1, name: "Greece", url: `${SITE}/places/greece` },
      { position: 2, name: "Portugal", url: `${SITE}/places/portugal` },
      { position: 3, name: "Spain", url: `${SITE}/places/spain` },
    ],
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd} fullBleed={true}>

  <!-- Nav extra: country pills (faded in by JS after hero scrolls) -->
  <Fragment slot="nav-extra">
    <div class="nav-pills" id="navPills" aria-label="Countries compared">
      <span class="nav-pill nav-pill--gr">🇬🇷 Greece</span>
      <span class="nav-pill nav-pill--pt">🇵🇹 Portugal</span>
      <span class="nav-pill nav-pill--es">🇪🇸 Spain</span>
    </div>
  </Fragment>

  <div data-page="comparison" data-compare="greece-portugal-spain">

    <!-- ── MASTHEAD ──────────────────────────────────────────────────────── -->
    <Masthead
      variant="compare"
      id="heroSection"
      title="Greece vs Portugal vs Spain"
      dateline={dateline}
      standfirst="Six measures, every figure sourced, dated, and confidence rated. We do not pick a winner for you."
    >
      <Fragment slot="title">Greece <em>vs</em> Portugal <em>vs</em> Spain</Fragment>

      <Fragment slot="media">
        {/* TODO: production needs licensed, optimised, locally hosted images
            (responsive srcset, modern format, e.g. AVIF/WebP). Replace these
            Unsplash hotlinks before launching. */}
        <div class="masthead-photos">
          <!-- Greece -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1603565816030-6b389eeb23cb?w=900&h=700&fit=crop&auto=format"
              alt="Acropolis above Athens at golden hour"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--gr">Greece</p>
              <p class="masthead-place">Athens on the Aegean</p>
            </div>
          </div>

          <!-- Portugal -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1762144062643-699966b2f7f9?w=900&h=700&fit=crop&auto=format"
              alt="Terracotta rooftops and the Tagus river, Lisbon"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--pt">Portugal</p>
              <p class="masthead-place">Lisbon on the Atlantic</p>
            </div>
          </div>

          <!-- Spain -->
          <div class="masthead-photo-wrap">
            <img
              class="masthead-photo"
              src="https://images.unsplash.com/photo-1764246195415-6e83157c2c74?w=900&h=700&fit=crop&auto=format"
              alt="Ornate arched courtyard in Seville"
              loading="lazy"
              decoding="async"
              width="900"
              height="700"
            />
            <div class="masthead-caption">
              <p class="masthead-country masthead-country--es">Spain</p>
              <p class="masthead-place">Seville in the south</p>
            </div>
          </div>
        </div>
      </Fragment>
    </Masthead>

    <!-- ── FENCE (above tabs, above first data claim) ──────────────────── -->
    <div class="fence-wrap">
      <FenceBlock hasLegalClaims={true} />
    </div>

    <!-- ── TABS ──────────────────────────────────────────────────────────── -->
    <div class="tabs-section">
      <div class="tabs-list" role="tablist" aria-label="Filter by scenario">
        <button class="tab-btn active" role="tab" aria-selected="true"  data-tab="all"    aria-controls="comparison">All metrics</button>
        <button class="tab-btn"        role="tab" aria-selected="false" data-tab="taxes"  aria-controls="comparison">Lower my taxes</button>
        <button class="tab-btn"        role="tab" aria-selected="false" data-tab="remote" aria-controls="comparison">Work remotely</button>
        <button class="tab-btn"        role="tab" aria-selected="false" data-tab="retire" aria-controls="comparison">Retire abroad</button>
