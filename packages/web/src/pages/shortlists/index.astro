---
import { shortlists } from "@where/data";
import FenceBlock from "../../components/FenceBlock.astro";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/jsonld";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/shortlists`;
const title = "Shortlists | My Second Country";
const description =
  "Ranked, cited shortlists of EU countries by tax, income, and residency criteria. Every result is derived from sourced place data.";

const jsonLd = [
  itemListJsonLd({
    url: canonical,
    items: shortlists.map((s, i) => ({
      position: i + 1,
      name: s.title,
      url: `${SITE}/shortlists/${s.slug}`,
    })),
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="corridor-page">
    <nav class="corridor-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Shortlists</span>
    </nav>

    <header class="corridor-hero">
      <p class="corridor-kicker">Shortlists</p>
      <h1 class="corridor-title">Ranked files, with the math visible.</h1>
      <p class="corridor-lead">
        Each shortlist applies a named filter and rank rule to the same cited place
        records, so the order can be checked rather than trusted.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    <section class="corridor-section" aria-labelledby="shortlist-files">
      <div class="corridor-section-head">
        <div>
          <p class="corridor-count">{shortlists.length} live</p>
          <h2 id="shortlist-files">Open shortlists</h2>
        </div>
        <p class="corridor-section-note">
          These are screening views, not recommendations. The ranking changes when the
          filters or source records change.
        </p>
      </div>
      <div class="corridor-grid">
        {
          shortlists.map((shortlist) => (
            <a class="corridor-card" href={`/shortlists/${shortlist.slug}`}>
              <span class="corridor-card__meta">{shortlist.constraint.rank.byKey}</span>
              <div>
                <h3 class="corridor-card__title">{shortlist.title}</h3>
                <p class="corridor-card__copy">{shortlist.intro}</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </article>
</Base>
