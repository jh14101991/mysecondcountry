---
import {
  DEFAULT_STALENESS_DAYS,
  isStale,
  placePath,
  places,
  type Shortlist,
  shortlistBySlug,
  shortlists,
  variableByKey,
} from "@where/data";
import { evaluateShortlist } from "@where/engine";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CiteThis from "../../components/CiteThis.astro";
import ConfidenceMark from "../../components/ConfidenceMark.astro";
import FactsTable from "../../components/FactsTable.astro";
import FenceBlock from "../../components/FenceBlock.astro";
import Masthead from "../../components/Masthead.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Base from "../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  itemListJsonLd,
  maxVerifiedDate,
} from "../../lib/jsonld.ts";

export function getStaticPaths() {
  return shortlists.map((shortlist) => ({
    params: { slug: shortlist.slug },
    props: { shortlist },
  }));
}

interface Props {
  shortlist: Shortlist;
}

const { shortlist } = Astro.props;

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/shortlists/${shortlist.slug}`;

// Evaluate the shortlist against country-level places to get ranked, cited items
const countryPlaces = places.filter((p) => p.granularity === "country");
const items = evaluateShortlist(shortlist.constraint, countryPlaces);

// Collect all cited values for dateline and CiteThis
const allCited = items.flatMap((item) => item.citedFields.map((f) => f.cited));
const maxDate = maxVerifiedDate(allCited);
const uniqueSources = new Set(allCited.map((c) => c.sourceUrl));
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: uniqueSources.size,
});

const stale = allCited.filter((c) => isStale(c));
const staleDays = stale.length
  ? Math.min(
      ...stale.map(
        (c) => c.stalenessDays ?? (c.category ? DEFAULT_STALENESS_DAYS[c.category] : 180),
      ),
    )
  : null;

const breadcrumbItems = [
  { name: "Shortlists", href: "/shortlists" },
  { name: shortlist.title, href: `/shortlists/${shortlist.slug}` },
];

const citeLines = items.flatMap((item) =>
  item.citedFields.map((f) => ({
    sourceName: f.cited.sourceName,
    verifiedDate: f.cited.verifiedDate,
    citationUrl: `${canonical}#${item.placeId}-${f.key}`,
  })),
);

const relatedLinks = shortlist.relatedSlugs
  .map((slug) => {
    const related = shortlistBySlug(slug);
    if (!related) return null;
    return { label: related.title, href: `/shortlists/${related.slug}` };
  })
  .filter((l): l is { label: string; href: string } => l !== null);

const title = `${shortlist.title} | My Second Country`;
const expectedKeys = [
  shortlist.constraint.rank.byKey,
  ...shortlist.constraint.filters.map((f) => f.key),
  ...(shortlist.constraint.display ?? []),
].filter((key, index, keys) => keys.indexOf(key) === index);
const rankLabel = variableByKey(shortlist.constraint.rank.byKey)?.label ?? shortlist.constraint.rank.byKey;

function formatCitedValue(value: unknown, unit?: string) {
  if (typeof value === "boolean") return value ? "Yes" : "No";
  const label = typeof value === "number" ? value.toLocaleString("en-US") : String(value);
  return unit ? `${label} ${unit}` : label;
}

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: shortlist.title,
    description: shortlist.intro,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  itemListJsonLd({
    url: canonical,
    items: items.map((item) => {
      const place = countryPlaces.find((p) => p.id === item.placeId);
      return {
        position: item.rank,
        name: item.name,
        url: place ? `${SITE}${placePath(place)}` : `${SITE}/places/${item.placeId}`,
      };
    }),
  }),
];
---

<Base title={title} description={shortlist.metaDescription ?? shortlist.intro.slice(0, 155)} canonical={canonical} jsonLd={jsonLd}>
  <article>
    <Breadcrumb items={breadcrumbItems} />

    <Masthead variant="topic" title={shortlist.title} dateline={dateline} />

    <FenceBlock hasLegalClaims={true} staleDays={staleDays} />

    <section aria-labelledby="intro-h">
      <SectionHeading as="h2" id="intro-h">About this shortlist</SectionHeading>
      <p class="intro-text">{shortlist.intro}</p>
    </section>

    <section aria-labelledby="ranked-h">
      <SectionHeading as="h2" id="ranked-h">Ranked results</SectionHeading>
      {items.length === 0 && (
        <p class="no-results">No places currently match this constraint. Check the screener for a broader search.</p>
      )}
      <ol class="ranked-list">
        {items.map((item) => {
          const place = countryPlaces.find((p) => p.id === item.placeId);
          const href = place ? placePath(place) : `/places/${item.placeId}`;
          const rows = item.citedFields
            .filter(
              (f) =>
                typeof f.cited.value === "number" ||
                typeof f.cited.value === "string" ||
                typeof f.cited.value === "boolean",
            )
            .map((f) => ({
              key: f.key,
              label: f.label,
              cited:
                typeof f.cited.value === "boolean"
                  ? { ...f.cited, value: f.cited.value ? "Yes" : "No" }
                  : f.cited,
              unit: variableByKey(f.key)?.unit,
            }));
          const decisiveRows = rows.slice(0, 3);
          const rowKeys = new Set(rows.map((row) => row.key));
          const missingKeys = expectedKeys.filter((key) => !rowKeys.has(key));
          return (
            <li class="ranked-item" id={item.placeId}>
              <span class="ranked-number">{item.rank}</span>
              <div class="ranked-body">
                <div class="ranked-topline">
                  <h3 class="ranked-name">
                    <a href={href}>{item.name}</a>
                  </h3>
                  <p class="ranked-match">Ranked by {rankLabel.toLowerCase()}.</p>
                </div>
                {decisiveRows.length > 0 && (
                  <ul class="reason-list" aria-label={`Decisive cited reasons for ${item.name}`}>
                    {decisiveRows.map((row) => (
                      <li class="reason-item" id={`${item.placeId}-${row.key}`}>
                        <span class="reason-label">{row.label}</span>
                        <span class="reason-value">{formatCitedValue(row.cited.value, row.unit)}</span>
                        <span class="reason-source">
                          <ConfidenceMark level={row.cited.confidence} />
                          <span class="reason-source__text">
                            <a href={row.cited.sourceUrl} target="_blank" rel="noopener nofollow">
                              {row.cited.sourceName}
                            </a>
                            <span>Verified {row.cited.verifiedDate}</span>
                            <span>{row.cited.granularity} data</span>
                          </span>
                        </span>
                      </li>
                    ))}
                  </ul>
                )}
                {missingKeys.length > 0 && (
                  <p class="ranked-gap">
                    Source gap: {missingKeys.map((key) => variableByKey(key)?.label ?? key).join(", ")} not shown for this result. Unknown values are excluded from the rank row.
                  </p>
                )}
                {rows.length > 0 && (
                  <details class="ranked-evidence">
                    <summary>Inspect sources and full criteria</summary>
                    <FactsTable
                      caption={`Cited facts for ${item.name}`}
                      rows={rows}
                      placeGranularity={place?.granularity}
                      placeName={item.name}
                    />
                  </details>
                )}
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    <section aria-labelledby="screener-link-h">
      <SectionHeading as="h2" id="screener-link-h">Preview the screener shape</SectionHeading>
      <p class="screener-note">
        The screener at <a href="/screener">/screener</a> shows the input shape for income,
        cost, climate, and tax filters. The current public action opens a live cited shortlist
        example rather than a dynamic result.
      </p>
    </section>

    <CiteThis lines={citeLines} />

    {relatedLinks.length > 0 && <RelatedLinks links={relatedLinks} />}
  </article>

  <style>
    .intro-text {
      max-width: var(--measure);
      font-family: var(--font-serif);
      font-size: 1rem;
      line-height: 1.6;
      color: var(--muted-strong);
      margin: 0 0 0.5rem;
    }
    .no-results {
      font-family: var(--font-serif);
      color: var(--muted-foreground);
      font-style: italic;
    }
    .ranked-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0;
      border-top: 1px solid var(--hairline-soft);
    }
    .ranked-item {
      display: grid;
      grid-template-columns: 2.5rem 1fr;
      gap: 0 1rem;
      align-items: start;
      padding: 1.45rem 0;
      border-bottom: 1px solid var(--hairline-soft);
    }
    .ranked-number {
      font-family: var(--font-mono);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--muted-foreground);
      padding-top: 0.15rem;
    }
    .ranked-body {
      min-width: 0;
    }
    .ranked-topline {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 0.85rem;
    }
    .ranked-name {
      font-family: var(--font-ui);
      font-size: 1.15rem;
      font-weight: 600;
      margin: 0;
    }
    .ranked-name a {
      color: var(--ink);
      text-decoration: none;
    }
    .ranked-name a:hover {
      text-decoration: underline;
    }
    .ranked-match {
      margin: 0;
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--muted-foreground);
    }
    .reason-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.85rem;
    }
    .reason-item {
      display: grid;
      grid-template-columns: minmax(9rem, 0.9fr) minmax(6rem, 0.45fr) minmax(14rem, 1.2fr);
      gap: 0.75rem;
      align-items: start;
      font-family: var(--font-ui);
    }
    .reason-label {
      color: var(--ink);
      font-weight: 600;
    }
    .reason-value {
      font-family: var(--font-mono);
      color: var(--ink);
      font-variant-numeric: tabular-nums;
    }
    .reason-source {
      display: flex;
      align-items: flex-start;
      gap: 0.55rem;
      min-width: 0;
    }
    .reason-source :global(.conf) {
      margin-top: 0.1rem;
      flex: 0 0 auto;
    }
    .reason-source__text {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem 0.45rem;
      min-width: 0;
      font-family: var(--font-mono);
      font-size: 0.76rem;
      line-height: 1.45;
      color: var(--muted-foreground);
    }
    .reason-source__text a {
      color: var(--accent);
    }
    .ranked-gap {
      margin: 0.9rem 0 0;
      font-family: var(--font-ui);
      font-size: 0.88rem;
      color: var(--muted-strong);
    }
    .ranked-evidence {
      margin-top: 1rem;
      border: 1px solid var(--hairline-soft);
      border-radius: 8px;
    }
    .ranked-evidence > summary {
      list-style: none;
      cursor: pointer;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0 0.9rem;
      font-family: var(--font-ui);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--ink);
    }
    .ranked-evidence > summary::-webkit-details-marker {
      display: none;
    }
    .ranked-evidence > summary:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }
    .ranked-evidence > summary::after {
      content: "+";
      font-family: var(--font-mono);
      color: var(--accent);
    }
    .ranked-evidence[open] > summary {
      border-bottom: 1px solid var(--hairline-soft);
    }
    .ranked-evidence[open] > summary::after {
      content: "-";
    }
    .screener-note {
      max-width: var(--measure);
      font-family: var(--font-serif);
      color: var(--muted-strong);
    }
    @media (max-width: 46rem) {
      .ranked-item {
        grid-template-columns: 2rem 1fr;
        gap: 0 0.75rem;
      }
      .reason-item {
        grid-template-columns: 1fr;
        gap: 0.25rem;
      }
    }
    @media (min-width: 769px) and (max-width: 980px) {
      :global(.nav-cta .btn-primary) {
        padding-inline: 1rem;
      }
    }
  </style>
</Base>
