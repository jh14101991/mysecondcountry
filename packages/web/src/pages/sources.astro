---
import {
  collectCitedValues,
  collectRegimeCitedValues,
  collectTopicsCitedValues,
  places,
  regimes,
  topics,
  type CitedCategory,
  type Confidence,
  type CitedValue,
} from "@where/data";
import ConfidenceMark from "../components/ConfidenceMark.astro";
import FenceBlock from "../components/FenceBlock.astro";
import Base from "../layouts/Base.astro";
import { articleJsonLd, breadcrumbJsonLd, maxVerifiedDate } from "../lib/jsonld.ts";

const SITE = "https://mysecondcountry.com";
const title = "Sources: where every My Second Country figure comes from";
const description =
  "A searchable source index for My Second Country relocation facts, grouped by dimension with confidence, host, and verified date.";
const canonical = `${SITE}/sources`;

type SourceRow = {
  url: string;
  name: string;
  host: string;
  verifiedDate: string;
  confidence: Confidence;
  category: CitedCategory | "uncategorized";
  covers: string[];
  text: string;
};

const categoryOrder: (CitedCategory | "uncategorized")[] = [
  "cost",
  "tax",
  "visa",
  "residency",
  "climate",
  "healthcare",
  "safety",
  "connectivity",
  "identity",
  "uncategorized",
];

const categoryLabels: Record<CitedCategory | "uncategorized", string> = {
  cost: "Cost",
  tax: "Tax",
  visa: "Visa",
  residency: "Residency",
  climate: "Climate",
  healthcare: "Healthcare",
  safety: "Safety",
  connectivity: "Connectivity",
  identity: "Identity",
  uncategorized: "Other",
};

function categoryFromPath(path: string, cited: CitedValue): CitedCategory | "uncategorized" {
  if (cited.category) return cited.category;
  if (path.startsWith("costOfLiving")) return "cost";
  if (path.startsWith("tax")) return "tax";
  if (path.startsWith("residency")) return "residency";
  if (path.startsWith("climate")) return "climate";
  if (path.startsWith("healthcare")) return "healthcare";
  if (path.startsWith("safety")) return "safety";
  return "uncategorized";
}

function weakestConfidence(values: Confidence[]): Confidence {
  if (values.includes("low")) return "low";
  if (values.includes("medium")) return "medium";
  return "high";
}

function hostFor(url: string): string {
  return new URL(url).hostname.replace(/^www\./, "");
}

const factEntries = [
  ...places.flatMap((place) =>
    collectCitedValues(place).map((fact) => ({
      owner: place.name,
      path: fact.path,
      cited: fact.cited,
    })),
  ),
  ...regimes.flatMap((regime) =>
    collectRegimeCitedValues(regime).map((fact) => ({
      owner: regime.name,
      path: fact.path,
      cited: fact.cited,
    })),
  ),
  ...topics.flatMap((topic) =>
    collectTopicsCitedValues(topic).map((fact) => ({
      owner: topic.title,
      path: fact.path,
      cited: fact.cited,
    })),
  ),
];

const byUrl = new Map<
  string,
  {
    name: string;
    host: string;
    verifiedDates: string[];
    confidences: Confidence[];
    categories: (CitedCategory | "uncategorized")[];
    covers: string[];
  }
>();

for (const entry of factEntries) {
  const hit = byUrl.get(entry.cited.sourceUrl) ?? {
    name: entry.cited.sourceName,
    host: hostFor(entry.cited.sourceUrl),
    verifiedDates: [],
    confidences: [],
    categories: [],
    covers: [],
  };
  hit.verifiedDates.push(entry.cited.verifiedDate);
  hit.confidences.push(entry.cited.confidence);
  hit.categories.push(categoryFromPath(entry.path, entry.cited));
  hit.covers.push(`${entry.owner}: ${entry.path}`);
  byUrl.set(entry.cited.sourceUrl, hit);
}

const sourceRows: SourceRow[] = Array.from(byUrl.entries())
  .map(([url, row]) => {
    const primaryCategory =
      categoryOrder.find((category) => row.categories.includes(category)) ?? "uncategorized";
    const covers = Array.from(new Set(row.covers));
    return {
      url,
      name: row.name,
      host: row.host,
      verifiedDate: maxVerifiedDate(row.verifiedDates.map((verifiedDate) => ({ verifiedDate }))),
      confidence: weakestConfidence(row.confidences),
      category: primaryCategory,
      covers,
      text: [row.name, row.host, primaryCategory, covers.join(" ")]
        .join(" ")
        .toLowerCase(),
    };
  })
  .sort((a, b) => {
    const cat = categoryOrder.indexOf(a.category) - categoryOrder.indexOf(b.category);
    if (cat !== 0) return cat;
    return a.name.localeCompare(b.name);
  });

const groups = categoryOrder
  .map((category) => ({
    category,
    label: categoryLabels[category],
    rows: sourceRows.filter((row) => row.category === category),
  }))
  .filter((group) => group.rows.length > 0);

const maxDate = maxVerifiedDate(factEntries.map((entry) => entry.cited));
const highConfidenceCount = sourceRows.filter((row) => row.confidence === "high").length;
const watchCount = sourceRows.filter((row) => row.confidence !== "high").length;
const fastRefreshCount = sourceRows.filter((row) =>
  ["tax", "visa", "residency"].includes(row.category),
).length;

const passportItems = [
  {
    label: "What MSC knows",
    stat: `${factEntries.length} cited facts`,
    text: `${sourceRows.length} unique sources feed the current public dataset across ${groups.length} evidence dimensions.`,
  },
  {
    label: "What MSC trusts",
    stat: `${highConfidenceCount} high-confidence sources`,
    text: "Official, statistical, or directly published records carry the highest confidence tier. Other sources stay labelled.",
  },
  {
    label: "What MSC refreshes",
    stat: `${fastRefreshCount} fast-watch sources`,
    text: "Tax, visa, and residency sources sit on shorter freshness windows because rules change more often.",
  },
  {
    label: "What MSC still marks as gaps",
    stat: `${watchCount} watch items`,
    text: "Medium and low-confidence records, proxy measures, and held coverage remain visible instead of being blended into the result.",
  },
];
const breadcrumbItems = [
  { name: "Home", href: "/" },
  { name: "Sources", href: "/sources" },
];

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: title,
    description,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  {
    "@context": "https://schema.org",
    "@type": "DataCatalog",
    "@id": `${canonical}#catalog`,
    name: "My Second Country source index",
    description,
    url: canonical,
    dateModified: maxDate,
    dataset: sourceRows.map((row) => ({
      "@type": "Dataset",
      name: row.name,
      url: row.url,
      dateModified: row.verifiedDate,
      measurementTechnique: `${row.confidence} confidence`,
    })),
  },
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="sources" data-page="sources">
    <nav class="breadcrumb sources-bc" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li><span aria-current="page">Sources</span></li>
      </ol>
    </nav>

    <header class="sources-head">
      <p class="overline">Sources</p>
      <h1>The source passport before the register.</h1>
      <p class="sources-summary">
        Start with what the dataset knows, trusts, refreshes, and still treats as a
        gap. The searchable register follows below.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    <section class="source-passport" aria-labelledby="source-passport-title">
      <div class="source-passport__head">
        <p class="overline">Source passport</p>
        <h2 id="source-passport-title">Four checks before the list.</h2>
      </div>
      <div class="source-passport__grid">
        {
          passportItems.map((item) => (
            <article class="source-passport__item">
              <p>{item.label}</p>
              <strong>{item.stat}</strong>
              <span>{item.text}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="register-intro" aria-labelledby="source-register-title">
      <p class="overline">Register</p>
      <h2 id="source-register-title">Search the cited source register.</h2>
      <p>
        Search by source, host, country, page, or dimension. Each row keeps its
        weakest confidence tier and latest verified date visible.
      </p>
    </section>

    <div class="src-controls">
      <div class="src-search-wrap">
        <span class="src-search-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M11 11l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </span>
        <label class="sr-only-label" for="src-search">Search sources</label>
        <input
          class="src-search"
          id="src-search"
          type="search"
          placeholder="Search sources, for example Eurostat or AIMA"
          autocomplete="off"
        />
      </div>
      <div class="srcfilter" role="group" aria-label="Filter by dimension">
        <button class="srcfilter__btn" type="button" data-dim="all" aria-pressed="true">All</button>
        {
          groups.map((group) => (
            <button class="srcfilter__btn" type="button" data-dim={group.category} aria-pressed="false">
              {group.label}
            </button>
          ))
        }
      </div>
      <p class="src-count" id="src-count" aria-live="polite"></p>
    </div>

    <div class="src-groups">
      {
        groups.map((group) => (
          <section class="src-group" data-dim={group.category}>
            <h2 class="src-group__label">
              {group.label}
              <span class="src-group__count">{group.rows.length}</span>
            </h2>
            <ul class="src-list">
              {
                group.rows.map((row) => (
                  <li class="src" data-dim={row.category} data-text={row.text}>
                    <a class="src__name" href={row.url} target="_blank" rel="noopener noreferrer nofollow">
                      {row.name}
                      <svg class="src__ext" width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M2 12L12 2M12 2H5M12 2V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                    <p class="src__covers">{row.covers.slice(0, 4).join("; ")}</p>
                    <div class="src__prov">
                      <span class="src__conf"><ConfidenceMark level={row.confidence} /></span>
                      <span class="src__sep" aria-hidden="true">/</span>
                      <span class="src__host">{row.host}</span>
                      <span class="src__sep" aria-hidden="true">/</span>
                      <span class="src__date">verified {row.verifiedDate}</span>
                    </div>
                  </li>
                ))
              }
            </ul>
          </section>
        ))
      }
      <p class="src-empty" id="src-empty" hidden>No sources match that filter.</p>
    </div>

    <section class="csfresh" aria-labelledby="freshness-title">
      <h2 class="csfresh__title" id="freshness-title">Freshness is part of the source record.</h2>
      <p class="csfresh__text">
        Tax, visa, and residency claims use short freshness windows. If a value becomes stale,
        the affected page should show a warning before the claim is treated as current.
      </p>
      <p class="csfresh__link"><a class="text-link" href="/methodology">Read the methodology</a></p>
    </section>
  </article>

  <style>
    :global(.footer-top[data-reveal]) {
      opacity: 1 !important;
      visibility: visible !important;
    }

    @media (min-width: 861px) and (max-width: 940px) {
      :global(.site-header .nav-cta) {
        display: none;
      }
    }

    .sources {
      max-width: 820px;
      margin: 0 auto;
      padding-bottom: clamp(64px, 9vw, 120px);
    }

    .sources-bc {
      margin-bottom: clamp(20px, 3vw, 30px);
    }

    .breadcrumb ol {
      display: flex;
      gap: 0.55rem;
      list-style: none;
      margin: 0;
      padding: 0;
      color: var(--stone);
      font: 500 var(--t-meta) var(--f-mono);
    }

    .breadcrumb a {
      color: var(--accent-dark);
      text-decoration: none;
    }

    .sources-head h1 {
      max-width: 15ch;
      font-size: clamp(2.35rem, 5vw, 4.2rem);
      line-height: 1.04;
    }

    .sources-summary {
      max-width: 60ch;
      color: var(--ink-soft);
      font-size: clamp(var(--t-lead), 1.4vw, 1.18rem);
      line-height: 1.55;
    }

    .source-passport {
      margin-top: clamp(28px, 4vw, 44px);
      padding-top: clamp(22px, 3vw, 34px);
      border-top: 1px solid var(--ink);
    }

    .source-passport__head {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 18px;
    }

    .source-passport__head h2,
    .register-intro h2 {
      max-width: 16ch;
      margin: 0;
      color: var(--ink);
      font-family: var(--f-display);
      font-size: clamp(1.6rem, 2.8vw, 2.3rem);
      font-weight: 400;
      line-height: 1.1;
    }

    .source-passport__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      border-top: 1px solid var(--hairline-soft);
      border-left: 1px solid var(--hairline-soft);
    }

    .source-passport__item {
      min-width: 0;
      padding: clamp(16px, 2.4vw, 22px);
      border-right: 1px solid var(--hairline-soft);
      border-bottom: 1px solid var(--hairline-soft);
      background: var(--surface);
    }

    .source-passport__item p {
      margin: 0 0 10px;
      color: var(--stone);
      font: 600 var(--t-meta) var(--f-mono);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .source-passport__item strong {
      display: block;
      color: var(--pop-ink);
      font-family: var(--f-display);
      font-size: clamp(1.45rem, 2.5vw, 2rem);
      font-weight: 400;
      line-height: 1.1;
    }

    .source-passport__item span {
      display: block;
      margin-top: 12px;
      color: var(--ink-soft);
      font-size: var(--t-bodysm);
      line-height: 1.55;
    }

    .register-intro {
      margin-top: clamp(34px, 5vw, 62px);
      padding-top: clamp(22px, 3vw, 34px);
      border-top: 1px solid var(--hairline-soft);
    }

    .register-intro p:last-child {
      max-width: 62ch;
      margin: 12px 0 0;
      color: var(--ink-soft);
      line-height: 1.62;
    }

    .sr-only-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .src-controls {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-top: clamp(24px, 3vw, 34px);
    }

    .src-search-wrap {
      position: relative;
      max-width: 420px;
    }

    .src-search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--stone);
      pointer-events: none;
    }

    .src-search {
      width: 100%;
      min-height: 48px;
      padding: 12px 14px 12px 40px;
      border: 1px solid var(--hairline-soft);
      border-radius: 4px;
      background: var(--paper);
      color: var(--ink);
      font: 1rem var(--f-ui);
    }

    .srcfilter {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .srcfilter__btn {
      min-height: 44px;
      padding: 10px 16px;
      border: 1px solid var(--hairline-soft);
      border-radius: 999px;
      background: var(--surface);
      color: var(--ink-soft);
      font: 500 var(--t-bodysm) var(--f-ui);
      cursor: pointer;
    }

    .srcfilter__btn:hover,
    .srcfilter__btn:focus-visible {
      border-color: var(--accent);
      color: var(--accent);
      outline: none;
    }

    .srcfilter__btn[aria-pressed="true"] {
      border-color: var(--accent);
      background: var(--accent);
      color: var(--paper);
    }

    .src-count,
    .src__host,
    .src__date {
      color: var(--stone);
      font: var(--t-meta) var(--f-mono);
    }

    .src-groups {
      margin-top: clamp(20px, 2.6vw, 30px);
    }

    .src-group {
      margin-top: clamp(28px, 3.4vw, 40px);
    }

    .src-group:first-child {
      margin-top: clamp(8px, 1.5vw, 16px);
    }

    .src-group[hidden],
    .src[hidden],
    .src-empty[hidden] {
      display: none;
    }

    .src-group__label {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin: 0 0 4px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--hairline-soft);
      color: var(--ink);
      font-family: var(--f-display);
      font-size: 1.35rem;
      font-weight: 400;
      letter-spacing: -0.012em;
      line-height: 1.2;
    }

    .src-group__count {
      color: var(--stone);
      font: var(--t-meta) var(--f-mono);
    }

    .src-list {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .src {
      padding: 16px 0;
      border-bottom: 1px solid var(--hairline-soft);
    }

    .src__name {
      color: var(--ink);
      font-weight: 500;
      line-height: 1.45;
      text-decoration: none;
    }

    .src__name:hover,
    .src__name:focus-visible {
      color: var(--accent);
      text-decoration: underline;
    }

    .src__ext {
      margin-left: 6px;
      color: var(--stone);
      vertical-align: baseline;
    }

    .src__covers {
      max-width: 64ch;
      margin: 5px 0 0;
      color: var(--stone);
      font-size: var(--t-bodysm);
      line-height: 1.5;
    }

    .src__prov {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 9px;
    }

    .src__conf {
      display: inline-flex;
      align-items: center;
    }

    .src__sep {
      color: var(--hairline-soft);
      font-size: var(--t-meta);
    }

    .src-empty {
      padding: 28px 0;
      color: var(--stone);
      font-style: italic;
    }

    .csfresh {
      margin-top: clamp(36px, 4.5vw, 56px);
      padding-top: clamp(22px, 2.8vw, 30px);
      border-top: 1px solid var(--hairline-soft);
    }

    .csfresh__title {
      margin: 0;
      color: var(--ink);
      font-family: var(--f-display);
      font-size: clamp(1.5rem, 2.4vw, 1.875rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1.15;
    }

    .csfresh__text {
      max-width: 70ch;
      margin-top: 12px;
      color: var(--ink-soft);
      line-height: 1.66;
    }

    .csfresh__link {
      margin-top: 14px;
    }

    @media (max-width: 600px) {
      .source-passport__head {
        display: block;
      }

      .source-passport__grid {
        grid-template-columns: 1fr;
      }

      .src-search-wrap {
        max-width: none;
      }
    }
  </style>
</Base>
