---
import { placeById, regimes } from "@where/data";
import FenceBlock from "../../components/FenceBlock.astro";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/jsonld";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/tax`;
const title = "Tax regimes | My Second Country";
const description =
  "Cited guides to special tax regimes for foreign residents and pensioners in EU countries. Every rate and condition is sourced.";

const resolvedRegimes = regimes
  .map((regime, i) => ({ regime, country: placeById(regime.countryId), index: i }))
  .filter((r): r is { regime: typeof r.regime; country: NonNullable<typeof r.country>; index: number } => r.country != null);

const jsonLd = [
  itemListJsonLd({
    url: canonical,
    items: resolvedRegimes.map((r, i) => ({
      position: i + 1,
      name: r.regime.name,
      url: `${SITE}/${r.country.slug}/tax/${r.regime.slug}`,
    })),
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="corridor-page">
    <nav class="corridor-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Tax regimes</span>
    </nav>

    <header class="corridor-hero">
      <p class="corridor-kicker">Tax</p>
      <h1 class="corridor-title">Tax regimes, source by source.</h1>
      <p class="corridor-lead">
        Special tax routes for foreign residents and pensioners, kept separate from
        country rankings and shown with their headline claims.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    <section class="corridor-section" aria-labelledby="tax-files">
      <div class="corridor-section-head">
        <div>
          <p class="corridor-count">{resolvedRegimes.length} live</p>
          <h2 id="tax-files">Regime files</h2>
        </div>
        <p class="corridor-section-note">
          These files screen published rules. They do not replace tax advice, and they
          should be checked against official sources before action.
        </p>
      </div>
      <div class="corridor-grid">
        {
          resolvedRegimes.map(({ regime, country }) => (
            <a class="corridor-card" href={`/${country.slug}/tax/${regime.slug}`}>
              <span class="corridor-card__meta">{country.name}</span>
              <div>
                <h3 class="corridor-card__title">{regime.name}</h3>
                <p class="corridor-card__copy">{regime.summary}</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </article>
</Base>
