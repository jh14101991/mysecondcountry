---
import { qa } from "@where/data";
import FenceBlock from "../../components/FenceBlock.astro";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/jsonld";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/answers`;
const title = "Cited answers | My Second Country";
const description =
  "Sourced answers to common questions about tax, visa, and residency in EU countries. Every answer is cited with a named source and verified date.";

const jsonLd = [
  itemListJsonLd({
    url: canonical,
    items: qa.map((q, i) => ({
      position: i + 1,
      name: q.question,
      url: `${SITE}/answers/${q.slug}`,
    })),
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="corridor-page">
    <nav class="corridor-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Answers</span>
    </nav>

    <header class="corridor-hero">
      <p class="corridor-kicker">Answers</p>
      <h1 class="corridor-title">Questions with a source attached.</h1>
      <p class="corridor-lead">
        Short answers for high-friction relocation questions, each tied to the cited
        rule or figure behind it.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    <section class="corridor-section" aria-labelledby="answer-files">
      <div class="corridor-section-head">
        <div>
          <p class="corridor-count">{qa.length} live</p>
          <h2 id="answer-files">Cited answers</h2>
        </div>
        <p class="corridor-section-note">
          Answers are compact by design. Follow the source record when the decision
          needs professional review.
        </p>
      </div>
      <div class="corridor-grid">
        {
          qa.map((entry) => (
            <a class="corridor-card" href={`/answers/${entry.slug}`}>
              <span class="corridor-card__meta">{entry.category}</span>
              <div>
                <h3 class="corridor-card__title">{entry.question}</h3>
                <p class="corridor-card__copy">{entry.answer}</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </article>
</Base>
