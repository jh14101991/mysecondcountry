---
import { qa } from "@where/data";
import FenceBlock from "../../components/FenceBlock.astro";
import Base from "../../layouts/Base.astro";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/answers`;
const title = "Cited answers | My Second Country";
const description =
  "Sourced answers to common questions about tax, visa, and residency in EU countries. Every answer is cited with a named source and verified date.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "QAPage",
    url: canonical,
    name: "Cited answers",
    mainEntity: {
      "@type": "Question",
      name: "Where can I find cited answers to EU tax and residency questions?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "My Second Country publishes sourced answers to common questions about tax, visa, and residency in EU countries. Every figure is cited with a named source and verified date.",
      },
    },
  },
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <h1>Cited answers</h1>

  <FenceBlock hasLegalClaims={true} />

  <ul>
    {
      qa.map((entry) => (
        <li>
          <a href={`/answers/${entry.slug}`}>{entry.question}</a>
        </li>
      ))
    }
  </ul>
</Base>
