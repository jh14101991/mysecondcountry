---
import {
  collectRegimeCitedValues,
  DEFAULT_STALENESS_DAYS,
  isStale,
  placeById,
  type Regime,
  regimes,
} from "@where/data";
import { regimeEligibilityCards } from "@where/engine";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import CiteThis from "../../../components/CiteThis.astro";
import ClaimCard from "../../../components/ClaimCard.astro";
import ConfidenceMark from "../../../components/ConfidenceMark.astro";
import DirectAnswer from "../../../components/DirectAnswer.astro";
import FactsTable from "../../../components/FactsTable.astro";
import FaqItem from "../../../components/FaqItem.astro";
import FenceBlock from "../../../components/FenceBlock.astro";
import Masthead from "../../../components/Masthead.astro";
import RelatedLinks from "../../../components/RelatedLinks.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import EmailCapture from "../../../components/EmailCapture.astro";
import IntroRequest from "../../../components/IntroRequest.astro";
import Base from "../../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../../lib/cited.ts";
import { showIntro } from "../../../lib/monetisation.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  definedTermJsonLd,
  faqPageJsonLd,
  maxVerifiedDate,
  regimeDatasetJsonLd,
} from "../../../lib/jsonld.ts";

export function getStaticPaths() {
  return regimes.map((regime) => {
    const country = placeById(regime.countryId)?.slug;
    if (!country) {
      throw new Error(`Regime ${regime.id} references unknown countryId "${regime.countryId}"`);
    }
    return { params: { country, slug: regime.slug }, props: { regime } };
  });
}

interface Props {
  regime: Regime;
}
const { regime } = Astro.props;

const SITE = "https://mysecondcountry.com";
const countryPlace = placeById(regime.countryId);
const country = countryPlace?.slug;
const countryName = countryPlace?.name ?? "this country";
const canonical = `${SITE}/${country}/tax/${regime.slug}`;

const allFacts = collectRegimeCitedValues(regime);
const maxDate = maxVerifiedDate(allFacts.map((f) => f.cited));
const uniqueSources = new Set(allFacts.map((f) => f.cited.sourceUrl));
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: uniqueSources.size,
});

// Self-activating staleness banner: if any cited value has aged past its window before a
// refresh merges, the banner appears automatically at build time (FENCE.md).
const stale = allFacts.filter((e) => isStale(e.cited));
const staleDays = stale.length
  ? Math.min(
      ...stale.map(
        (e) =>
          e.cited.stalenessDays ??
          (e.cited.category ? DEFAULT_STALENESS_DAYS[e.cited.category] : 180),
      ),
    )
  : null;

const eligibilityCards = regimeEligibilityCards(regime);

const rateDisplay =
  regime.rateType === "lumpSum"
    ? `EUR ${regime.headlineRate.value.toLocaleString("en-US")} per year`
    : `${regime.headlineRate.value}%`;
const rateApplies =
  regime.rateType === "lumpSum"
    ? `applies a lump-sum tax of ${rateDisplay} on ${regime.incomeBasis}`
    : `applies a flat ${regime.headlineRate.value}% rate on ${regime.incomeBasis}`;
const rateClause =
  regime.rateType === "lumpSum"
    ? `A lump sum of ${rateDisplay} on ${regime.incomeBasis}`
    : `A flat ${regime.headlineRate.value}% on ${regime.incomeBasis}`;
const rateRowLabel =
  regime.rateType === "lumpSum"
    ? `Annual lump-sum tax on ${regime.incomeBasis}`
    : `Flat tax rate on ${regime.incomeBasis}`;
const rateRowUnit = regime.rateType === "lumpSum" ? "EUR/year" : "%";

const breadcrumbItems = [
  { name: countryName, href: `/places/${country}` },
  { name: "Tax regimes", href: "/tax" },
  { name: regime.name, href: `/${country}/tax/${regime.slug}` },
];

const factRows = [
  { label: rateRowLabel, cited: regime.headlineRate, unit: rateRowUnit },
  { label: "Maximum regime duration", cited: regime.durationYears, unit: "years" },
];

const adviserVerificationItems =
  regime.id === "greece-foreign-pensioner-flat-tax"
    ? [
        "your prior Greek tax-residence history against the five-of-six-year rule;",
        "whether the country you transfer from has administrative cooperation in tax matters with Greece;",
        "the 31 March application timing for the tax year you are targeting;",
        "how your pension source, treaty position, payment timing, and Greek filing obligations apply to your own case.",
      ]
    : [];

const ificiContextRows =
  regime.id === "portugal-ifici"
    ? [
        regime.eligibility.priorRegimeExclusion
          ? {
              label: "Prior NHR or former-resident use",
              cited: regime.eligibility.priorRegimeExclusion,
              prose: true,
            }
          : null,
        regime.eligibility.knownCatch
          ? {
              label: "Foreign pension treatment",
              cited: regime.eligibility.knownCatch,
              prose: true,
            }
          : null,
        {
          label: "Prior Portuguese tax residence",
          cited: regime.eligibility.priorNonResidency,
          prose: true,
        },
      ].filter(
        (
          row,
        ): row is {
          label: string;
          cited: Regime["eligibility"][keyof Regime["eligibility"]];
          prose: true;
        } => row !== null,
      )
    : [];

// Alternatives: every other published regime, linked to its page. Evergreen.
const altRegimeLinks = regimes
  .filter((r) => r.id !== regime.id)
  .map((r) => {
    const cSlug = placeById(r.countryId)?.slug;
    return cSlug ? { label: `${r.name}`, href: `/${cSlug}/tax/${r.slug}` } : null;
  })
  .filter((l): l is { label: string; href: string } => l !== null);

type InternalLink = { label: string; href: string };
const regimeClusterMap: Record<string, { heading: string; links: InternalLink[] }> = {
  "greece-foreign-pensioner-flat-tax": {
    heading: "Greece 7 percent tax cluster",
    links: [
      {
        label: "Does Greece tax foreign pensions at 7 percent?",
        href: "/answers/does-greece-tax-foreign-pensions-at-7-percent",
      },
      {
        label: "Who does not qualify for Greece 7 percent pensioner tax?",
        href: "/answers/who-does-not-qualify-for-greece-7-percent-pensioner-tax",
      },
      {
        label: "What happens when Greece 7 percent pensioner tax expires?",
        href: "/answers/what-happens-when-greece-7-percent-pensioner-tax-expires",
      },
      {
        label: "Greece 7 percent pension tax checklist",
        href: "/tools/greece-7-percent-pension-tax-checklist",
      },
      { label: "Greece country dossier", href: "/places/greece" },
      { label: "Crete region dossier", href: "/places/greece/crete" },
    ],
  },
  "greece-non-dom-lump-sum-tax": {
    heading: "Greece tax context",
    links: [
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      { label: "Greece golden visa price tiers", href: "/topics/greece-golden-visa-price-tiers" },
      { label: "Greece country dossier", href: "/places/greece" },
      { label: "Crete region dossier", href: "/places/greece/crete" },
      {
        label: "Greece vs Portugal vs Spain comparison",
        href: "/compare/greece-portugal-spain",
      },
    ],
  },
  "portugal-ifici": {
    heading: "Portugal IFICI cluster",
    links: [
      { label: "Portugal IFICI, the NHR successor", href: "/topics/portugal-ifici-the-nhr-successor" },
      {
        label: "Is Portugal's NHR tax regime still available?",
        href: "/answers/is-portugals-nhr-tax-regime-still-available",
      },
      {
        label: "Portugal IFICI eligibility checklist",
        href: "/tools/portugal-ifici-eligibility-checklist",
      },
      { label: "Portugal country dossier", href: "/places/portugal" },
      {
        label: "Greece vs Portugal vs Spain comparison",
        href: "/compare/greece-portugal-spain",
      },
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
    ],
  },
  "italy-pensioner-7-percent-flat-tax": {
    heading: "Pension tax context",
    links: [
      {
        label: "Greece foreign-pensioner 7 percent flat tax",
        href: "/greece/tax/foreign-pensioner-flat-tax",
      },
      { label: "Italy country dossier", href: "/places/italy" },
      {
        label: "EU expat tax regimes by rate",
        href: "/shortlists/eu-expat-tax-regimes-by-rate",
      },
      {
        label: "Greece vs Portugal vs Spain comparison",
        href: "/compare/greece-portugal-spain",
      },
    ],
  },
};
const currentRegimeHref = `/${country}/tax/${regime.slug}`;
const regimeCluster = regimeClusterMap[regime.id];
const regimeClusterLinks = regimeCluster
  ? regimeCluster.links.filter((link) => link.href !== currentRegimeHref)
  : [];

const citeLines = allFacts.map(({ path, cited }) => ({
  sourceName: cited.sourceName,
  verifiedDate: cited.verifiedDate,
  citationUrl: `${canonical}#${path}`,
}));

// FAQ pairs, cited. Each question is rendered as a visible <h3> and mirrored into FAQPage
// JSON-LD; the two must match (assert-faq-jsonld).
const rateSource = `${regime.headlineRate.sourceName}, verified ${regime.headlineRate.verifiedDate}`;
const durationSource = `${regime.durationYears.sourceName}, verified ${regime.durationYears.verifiedDate}`;
const faqs = [
  {
    question: `What is the headline rate of the ${regime.name}?`,
    answer: `${rateClause} (${rateSource}). It is one published regime among several; eligibility differs by regime, so verify yours with a licensed professional.`,
  },
  {
    question: `How long does the ${regime.name} last?`,
    answer: `Up to ${regime.durationYears.value} years for a qualifying applicant (${durationSource}). Non-compliance in any year can end it early; see the disqualifying conditions above.`,
  },
];

const title = `${regime.name}: eligibility rules and tax facts | My Second Country`;

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: regime.name,
    description: regime.summary,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  regimeDatasetJsonLd(regime, SITE),
  definedTermJsonLd({
    url: canonical,
    name: regime.name,
    description: `${regime.summary.split(". ")[0]}.`,
    siteUrl: SITE,
  }),
  faqPageJsonLd(faqs),
];
---

<Base title={title} description={regime.summary} canonical={canonical} jsonLd={jsonLd}>
  <article>
    <Breadcrumb items={breadcrumbItems} />

    <Masthead variant="topic" title={regime.name} dateline={dateline} />

    <FenceBlock hasLegalClaims={true} staleDays={staleDays} />

    <p class="lede">{regime.summary}</p>

    <div class="rate-figure">
      <span class="overline">Headline rate</span>
      <p class="rate-figure__val num">{rateDisplay}</p>
      <p class="rate-figure__basis">
        on {regime.incomeBasis}, for up to {regime.durationYears.value} years
      </p>
      <p class="rate-figure__prov">
        <ConfidenceMark level={regime.headlineRate.confidence} />
        <a href={regime.headlineRate.sourceUrl} target="_blank" rel="noopener nofollow">
          {regime.headlineRate.sourceName}
        </a>
        <span class="rate-figure__date">verified {regime.headlineRate.verifiedDate}</span>
      </p>
    </div>

    <DirectAnswer question={`How does the ${regime.name} work?`}>
      <p>
        {countryName} {rateApplies} under this regime, for up to {regime.durationYears.value} years
        ({rateSource}). The published eligibility rules are below; confirm your own position with a
        licensed professional and the official source.
      </p>
    </DirectAnswer>

    <section aria-labelledby="dealbreakers-h">
      <SectionHeading as="h2" id="dealbreakers-h">What would disqualify you</SectionHeading>
      <p class="section-note">
        These are published eligibility rules reported from their source on the verified date.
        Each rule describes a condition that, if it does not hold, would exclude an applicant from
        this regime. They are not advice and they change. Confirm your own position with a licensed
        professional and the official source.
      </p>
      <ul class="claim-cards" role="list">
        {
          eligibilityCards.map((card) => (
            <ClaimCard framing={card.framing} cited={card.cited} variant="dealbreaker" />
          ))
        }
      </ul>
    </section>

    {adviserVerificationItems.length > 0 && (
      <section aria-labelledby="adviser-verification-h">
        <SectionHeading as="h2" id="adviser-verification-h">
          What to verify with a tax adviser
        </SectionHeading>
        <p class="section-note">
          Use this page to identify the published rule, then verify the individual application
          outside this site. In particular, check:
        </p>
        <ul class="verification-list">
          {adviserVerificationItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    )}

    {ificiContextRows.length > 0 && (
      <section aria-labelledby="ifici-context-h">
        <SectionHeading as="h2" id="ifici-context-h">
          NHR is closed, IFICI is narrower
        </SectionHeading>
        <p class="section-note">
          The former NHR regime and IFICI should not be read as the same thing. The cited fields
          below are the main narrowing points carried by this page.
        </p>
        <FactsTable caption="Cited IFICI context facts" rows={ificiContextRows} />
      </section>
    )}

    {showIntro(regime.id) && <IntroRequest pageId={regime.id} corridorLabel="Portugal IFICI" />}

    <section aria-labelledby="headline-facts-h">
      <SectionHeading as="h2" id="headline-facts-h">Headline facts</SectionHeading>
      <FactsTable caption={`Cited headline facts for ${regime.name}`} rows={factRows} />
    </section>

    <section aria-labelledby="faq-h">
      <SectionHeading as="h2" id="faq-h">Common questions</SectionHeading>
      {faqs.map((f) => (
        <FaqItem question={f.question}>
          <p>{f.answer}</p>
        </FaqItem>
      ))}
    </section>

    <CiteThis lines={citeLines} />

    {regimeCluster && regimeClusterLinks.length > 0 && (
      <RelatedLinks heading={regimeCluster.heading} links={regimeClusterLinks} />
    )}

    <RelatedLinks
      links={[
        {
          label: `${countryName}: cited cost, climate, residency and tax facts`,
          href: `/places/${country}`,
        },
        {
          label: "Greece vs Portugal vs Spain: a cited comparison",
          href: "/compare/greece-portugal-spain",
        },
      ]}
    />

    {altRegimeLinks.length > 0 && (
      <RelatedLinks heading="Alternative regimes" links={altRegimeLinks} />
    )}

    <EmailCapture />

    <section aria-labelledby="how-to-read-h" class="how-to-read">
      <SectionHeading as="h2" id="how-to-read-h">How to read this page</SectionHeading>
      <p>
        Every figure above is a cited claim: a value, the named source, the date we last verified
        it, and a confidence mark. A high mark means an official statistical body or primary law.
        Medium means an official authority read through a secondary source. Low means a directional
        figure to check yourself.
      </p>
    </section>
  </article>

  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="shell">
      <div class="cta-card">
        <span class="overline cta-eyebrow">Build my shortlist</span>
        <h2 id="cta-heading" class="display-section cta-headline">See where this regime fits your move.</h2>
        <p class="cta-sub">
          Tell us your income, visa needs, and what you want from a place. You get back a sourced
          shortlist of countries, regions, and towns, every figure cited.
        </p>
        <div class="cta-actions">
          <a href="/screener" class="btn-primary">
            Build my shortlist
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 12L12 2M12 2H5M12 2V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href={`/places/${country}`} class="text-link">{countryName} dossier</a>
        </div>
        <p class="cta-reassure">Free to start. Sourced screening, not advice.</p>
      </div>
    </div>
  </section>

  <style>
    .lede {
      max-width: 62ch;
      font-family: var(--f-ui);
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--ink-soft);
      margin: 0 0 0.5rem;
    }
    .rate-figure {
      margin: 1.75rem 0 2.25rem;
      padding-bottom: 1.75rem;
      border-bottom: 1px solid var(--hairline-soft);
    }
    .rate-figure__val {
      font-family: var(--f-mono);
      font-variant-numeric: tabular-nums;
      font-size: clamp(3rem, 8vw, 5.5rem);
      line-height: 1;
      color: var(--ink);
      margin: 0.5rem 0 0;
    }
    .rate-figure__basis {
      font-family: var(--f-ui);
      font-size: 1.05rem;
      color: var(--ink-soft);
      margin: 0.6rem 0 0;
      max-width: 50ch;
    }
    .rate-figure__prov {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1rem;
      font-family: var(--f-mono);
      font-size: var(--t-meta);
      color: var(--stone);
    }
    .rate-figure__prov a {
      color: var(--accent);
    }
    .rate-figure__date {
      color: var(--stone);
    }
    .section-note {
      max-width: 62ch;
      color: var(--stone);
      font-family: var(--f-ui);
      font-size: 0.98rem;
      margin-bottom: 1.2rem;
    }
    .claim-cards {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0;
    }
    .how-to-read {
      margin-top: 3rem;
      padding-top: 1.4rem;
      border-top: 1px solid var(--hairline-soft);
    }
    .how-to-read :global(.section-heading--heading) {
      margin-top: 0;
    }
    .how-to-read p {
      max-width: 62ch;
      margin: 0;
      font-family: var(--f-ui);
      color: var(--ink-soft);
    }
  </style>
</Base>
