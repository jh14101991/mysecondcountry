---
import {
  collectRegimeCitedValues,
  DEFAULT_STALENESS_DAYS,
  isStale,
  placeById,
  type Regime,
  regimes,
} from "@where/data";
import { regimeEligibilityCards } from "@where/engine";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import CiteThis from "../../../components/CiteThis.astro";
import ClaimCard from "../../../components/ClaimCard.astro";
import DirectAnswer from "../../../components/DirectAnswer.astro";
import FactsTable from "../../../components/FactsTable.astro";
import FaqItem from "../../../components/FaqItem.astro";
import FenceBlock from "../../../components/FenceBlock.astro";
import Masthead from "../../../components/Masthead.astro";
import RelatedLinks from "../../../components/RelatedLinks.astro";
import SectionHeading from "../../../components/SectionHeading.astro";
import Base from "../../../layouts/Base.astro";
import { buildDateline, monthYearLabel } from "../../../lib/cited.ts";
import {
  articleJsonLd,
  breadcrumbJsonLd,
  definedTermJsonLd,
  faqPageJsonLd,
  maxVerifiedDate,
  regimeDatasetJsonLd,
} from "../../../lib/jsonld.ts";

export function getStaticPaths() {
  return regimes.map((regime) => {
    const country = placeById(regime.countryId)?.slug;
    if (!country) {
      throw new Error(`Regime ${regime.id} references unknown countryId "${regime.countryId}"`);
    }
    return { params: { country, slug: regime.slug }, props: { regime } };
  });
}

interface Props {
  regime: Regime;
}
const { regime } = Astro.props;

const SITE = "https://mysecondcountry.com";
const countryPlace = placeById(regime.countryId);
const country = countryPlace?.slug;
const countryName = countryPlace?.name ?? "this country";
const canonical = `${SITE}/${country}/tax/${regime.slug}`;

const allFacts = collectRegimeCitedValues(regime);
const maxDate = maxVerifiedDate(allFacts.map((f) => f.cited));
const uniqueSources = new Set(allFacts.map((f) => f.cited.sourceUrl));
const dateline = buildDateline({
  citedLabel: monthYearLabel(maxDate),
  sourceCount: uniqueSources.size,
});

// Self-activating staleness banner: if any cited value has aged past its window before a
// refresh merges, the banner appears automatically at build time (FENCE.md).
const stale = allFacts.filter((e) => isStale(e.cited));
const staleDays = stale.length
  ? Math.min(
      ...stale.map(
        (e) =>
          e.cited.stalenessDays ??
          (e.cited.category ? DEFAULT_STALENESS_DAYS[e.cited.category] : 180),
      ),
    )
  : null;

const eligibilityCards = regimeEligibilityCards(regime);

const rateDisplay =
  regime.rateType === "lumpSum"
    ? `EUR ${regime.headlineRate.value.toLocaleString("en-US")} per year`
    : `${regime.headlineRate.value}%`;
const rateApplies =
  regime.rateType === "lumpSum"
    ? `applies a lump-sum tax of ${rateDisplay} on ${regime.incomeBasis}`
    : `applies a flat ${regime.headlineRate.value}% rate on ${regime.incomeBasis}`;
const rateClause =
  regime.rateType === "lumpSum"
    ? `A lump sum of ${rateDisplay} on ${regime.incomeBasis}`
    : `A flat ${regime.headlineRate.value}% on ${regime.incomeBasis}`;
const rateRowLabel =
  regime.rateType === "lumpSum"
    ? `Annual lump-sum tax on ${regime.incomeBasis}`
    : `Flat tax rate on ${regime.incomeBasis}`;
const rateRowUnit = regime.rateType === "lumpSum" ? "EUR/year" : "%";

const breadcrumbItems = [
  { name: countryName, href: `/places/${country}` },
  { name: "Tax regimes" },
  { name: regime.name, href: `/${country}/tax/${regime.slug}` },
];

const factRows = [
  { label: rateRowLabel, cited: regime.headlineRate, unit: rateRowUnit },
  { label: "Maximum regime duration", cited: regime.durationYears, unit: "years" },
];

const citeLines = allFacts.map(({ path, cited }) => ({
  sourceName: cited.sourceName,
  verifiedDate: cited.verifiedDate,
  citationUrl: `${canonical}#${path}`,
}));

// FAQ pairs, cited. Each question is rendered as a visible <h3> and mirrored into FAQPage
// JSON-LD; the two must match (assert-faq-jsonld).
const rateSource = `${regime.headlineRate.sourceName}, verified ${regime.headlineRate.verifiedDate}`;
const durationSource = `${regime.durationYears.sourceName}, verified ${regime.durationYears.verifiedDate}`;
const faqs = [
  {
    question: `What is the headline rate of the ${regime.name}?`,
    answer: `${rateClause} (${rateSource}). It is one published regime among several; eligibility differs by regime, so verify yours with a licensed professional.`,
  },
  {
    question: `How long does the ${regime.name} last?`,
    answer: `Up to ${regime.durationYears.value} years for a qualifying applicant (${durationSource}). Non-compliance in any year can end it early; see the disqualifying conditions above.`,
  },
];

const title = `${regime.name}: eligibility rules and tax facts | My Second Country`;

const jsonLd = [
  articleJsonLd({
    url: canonical,
    headline: regime.name,
    description: regime.summary,
    dateModified: maxDate,
    siteUrl: SITE,
  }),
  breadcrumbJsonLd(breadcrumbItems, SITE),
  regimeDatasetJsonLd(regime, SITE),
  definedTermJsonLd({
    url: canonical,
    name: regime.name,
    description: `${regime.summary.split(". ")[0]}.`,
    siteUrl: SITE,
  }),
  faqPageJsonLd(faqs),
];
---

<Base title={title} description={regime.summary} canonical={canonical} jsonLd={jsonLd}>
  <article>
    <Breadcrumb items={breadcrumbItems} />

    <Masthead variant="topic" title={regime.name} dateline={dateline} />

    <FenceBlock hasLegalClaims={true} staleDays={staleDays} />

    <p class="lede">{regime.summary}</p>

    <DirectAnswer question={`How does the ${regime.name} work?`}>
      <p>
        {countryName} {rateApplies} under this regime, for up to {regime.durationYears.value} years
        ({rateSource}). The published eligibility rules are below; confirm your own position with a
        licensed professional and the official source.
      </p>
    </DirectAnswer>

    <section aria-labelledby="dealbreakers-h">
      <SectionHeading as="h2" id="dealbreakers-h">What would disqualify you</SectionHeading>
      <p class="section-note">
        These are published eligibility rules reported from their source on the verified date.
        Each rule describes a condition that, if it does not hold, would exclude an applicant from
        this regime. They are not advice and they change. Confirm your own position with a licensed
        professional and the official source.
      </p>
      <ul class="claim-cards" role="list">
        {
          eligibilityCards.map((card) => (
            <ClaimCard framing={card.framing} cited={card.cited} variant="dealbreaker" />
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="headline-facts-h">
      <SectionHeading as="h2" id="headline-facts-h">Headline facts</SectionHeading>
      <FactsTable caption={`Cited headline facts for ${regime.name}`} rows={factRows} />
    </section>

    <section aria-labelledby="faq-h">
      <SectionHeading as="h2" id="faq-h">Common questions</SectionHeading>
      {faqs.map((f) => (
        <FaqItem question={f.question}>
          <p>{f.answer}</p>
        </FaqItem>
      ))}
    </section>

    <CiteThis lines={citeLines} />

    <RelatedLinks
      links={[
        {
          label: `${countryName}: cited cost, climate, residency and tax facts`,
          href: `/places/${country}`,
        },
        {
          label: "Greece vs Portugal vs Spain: a cited comparison",
          href: "/compare/greece-portugal-spain",
        },
      ]}
    />

    <section aria-labelledby="how-to-read-h" class="how-to-read">
      <SectionHeading as="h2" id="how-to-read-h">How to read this page</SectionHeading>
      <p>
        Every figure above is a cited claim: a value, the named source, the date we last verified
        it, and a confidence mark. Verified means an official statistical body or primary law. Good
        means an official authority read through a secondary. Limited means a directional figure to
        check yourself.
      </p>
    </section>
  </article>

  <style>
    .lede {
      max-width: var(--measure);
      font-family: var(--font-serif);
      font-size: 1.05rem;
      line-height: 1.6;
      color: var(--muted-strong);
      margin: 0 0 0.5rem;
    }
    .section-note {
      max-width: var(--measure);
      color: var(--muted-foreground);
      font-family: var(--font-serif);
      font-size: 0.98rem;
      margin-bottom: 1.2rem;
    }
    .claim-cards {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .how-to-read {
      margin-top: 3rem;
      padding: 1.4rem 1.5rem;
      background: var(--card);
      border: 1px solid var(--rule);
      border-radius: var(--radius);
    }
    .how-to-read :global(.section-heading--heading) {
      margin-top: 0;
    }
    .how-to-read p {
      max-width: var(--measure);
      margin: 0;
      font-family: var(--font-serif);
      color: var(--muted-strong);
    }
  </style>
</Base>
