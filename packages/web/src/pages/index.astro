      <div class="footer-bottom">
        <span class="footer-copy">© 2026 My Second Country</span>
        <div class="footer-legal">
          <a href="/about">About</a>
          <a href="/screening-notice">Screening notice</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/sources">Sources</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script src="/mockups/_msc-system.js" is:inline></script>
<script>
/* GATE 12 — live shortlist demo (homepage-unique). Scenario chips
   re-rank the three places with the relevant cited figure; citations
   expand on tap. All figures are real, from packages/data/src. */
(function () {
  'use strict';
  var listEl = document.getElementById('ls-list');
  var nameEl = document.getElementById('ls-scenario-name');
  var rankedByEl = document.getElementById('ls-rankedby');
  if (!listEl) return;

  var DATE = '2026-06-24';
  var PLACES = {
    gr: { name: 'Chania, Crete', country: 'Greece' },
    pt: { name: 'Lisbon', country: 'Portugal' },
    es: { name: 'Valencia', country: 'Spain' }
  };

  var CONF = {
    medium: '<svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><rect x="0.5" y="0.5" width="9" height="9" fill="none" stroke="currentColor" stroke-width="1.25"/><rect x="0.5" y="0.5" width="4.75" height="9" fill="currentColor"/></svg>',
    high: '<svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><rect x="0.5" y="0.5" width="9" height="9" fill="currentColor" stroke="currentColor" stroke-width="1.25"/></svg>'
  };

  var SCEN = {
    tax: {
      name: 'lower my taxes',
      rankedBy: 'Ranked by lowest special-regime rate',
      rows: [
        { k: 'gr', val: '7', unit: '%', q: 'Pensioner, Art 5B', conf: 'medium', src: 'PwC Tax Summaries', host: 'taxsummaries.pwc.com', url: 'https://taxsummaries.pwc.com/greece/individual/other-tax-credits-and-incentives', ex: '7 percent on foreign-sourced income (Art 5B), up to 15 fiscal years.' },
        { k: 'pt', val: '20', unit: '%', q: 'IFICI regime', conf: 'medium', src: 'PwC Tax Summaries', host: 'taxsummaries.pwc.com', url: 'https://taxsummaries.pwc.com/portugal/individual/significant-developments', ex: 'IFICI provides a special 20 percent rate on eligible category A and B income.' },
        { k: 'es', val: '24', unit: '%', q: 'Beckham regime', conf: 'medium', src: 'PwC Tax Summaries', host: 'taxsummaries.pwc.com', url: 'https://taxsummaries.pwc.com/spain/individual/other-issues', ex: '24 percent for the first 600,000 euros of taxable income, then 47 percent.' }
      ]
    },
    remote: {
      name: 'work remotely',
      rankedBy: 'Ranked by lowest visa income floor',
      rows: [
        { k: 'es', val: '2,849', unit: '€/mo', q: 'Telework visa', conf: 'medium', src: 'Spain SMI, Real Decreto 126/2026', host: 'boe.es', url: 'https://www.boe.es/buscar/doc.php?id=BOE-A-2026-3815', date: '2026-06-28', ex: 'Spain telework visa: minimum income 200 percent of the SMI; the 2026 SMI is 17,094 euros/year (Real Decreto 126/2026), about 2,849 euros per month.' },
        { k: 'gr', val: '3,500', unit: '€/mo', q: 'Nomad permit', conf: 'medium', src: 'Greek Migration Ministry', host: 'migration.gov.gr', url: 'https://migration.gov.gr/en/gas/aitoyntes-kai-dikaioychoi/adeies-diamonis/', ex: 'Greece digital nomad permit: minimum net monthly income 3,500 euros.' },
        { k: 'pt', val: '3,680', unit: '€/mo', q: 'D8 visa', conf: 'medium', src: 'AIMA (Nomadas Digitais)', host: 'aima.gov.pt', url: 'https://aima.gov.pt/pt/trabalhar/autorizacao-de-residencia-para-o-exercicio-de-atividade-profissional-prestada-de-forma-remota-com-visto-de-residencia-para-o-exe', date: '2026-06-28', ex: 'Portugal D8: about 3,680 euros per month in 2026 (4x the minimum wage, RMMG 920 euros, Decreto-Lei 139/2025), assessed by AIMA.' }
      ]
    },
    retire: {
      name: 'retire abroad',
      rankedBy: 'Ranked by safety, Global Peace Index',
      rows: [
        { k: 'pt', val: '1.372', unit: '', q: 'Rank 7 of 163', conf: 'medium', src: 'IEP Global Peace Index 2024', host: 'visionofhumanity.org', url: 'https://www.visionofhumanity.org/wp-content/uploads/2024/06/GPI-2024-web.pdf', ex: 'Portugal 2024 Global Peace Index 1.372 (rank 7 of 163). Lower is more peaceful.' },
        { k: 'es', val: '1.597', unit: '', q: 'Rank 23 of 163', conf: 'medium', src: 'IEP Global Peace Index 2024', host: 'visionofhumanity.org', url: 'https://www.visionofhumanity.org/wp-content/uploads/2024/06/GPI-2024-web.pdf', ex: 'Spain 2024 Global Peace Index 1.597 (rank 23 of 163). Lower is more peaceful.' },
        { k: 'gr', val: '1.793', unit: '', q: 'Rank 40 of 163', conf: 'medium', src: 'IEP Global Peace Index 2024', host: 'visionofhumanity.org', url: 'https://www.visionofhumanity.org/wp-content/uploads/2024/06/GPI-2024-web.pdf', ex: 'Greece 2024 Global Peace Index 1.793 (rank 40 of 163). Lower is more peaceful.' }
      ]
    }
  };

  function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  var KEYS = ['gr', 'pt', 'es'];
  var rows = {};   // place key -> persistent <li> (reordered, not recreated, for the FLIP)
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function cellHTML(place, rankNum, r) {
    var id = 'ls-cp-' + r.k;
    var unit = r.unit ? '<span class="ls__unit">' + esc(r.unit) + '</span>' : '';
    return '<span class="ls__rank">' + rankNum + '</span>' +
      '<div class="ls__main">' +
        '<span class="ls__placeline"><span class="ls__placename">' + esc(place.name) + '</span></span>' +
        '<span class="ls__meta">' + esc(place.country) + ' · ' + esc(r.q) + '</span>' +
      '</div>' +
      '<div class="ls__right">' +
        '<span class="ls__val">' + esc(r.val) + unit + '</span>' +
        '<span class="ls__prov">' +
          '<span class="ls__conf" aria-label="Confidence: ' + r.conf + '">' + CONF[r.conf] + r.conf + '</span>' +
          '<span class="ls__sep" aria-hidden="true">·</span>' +
          '<button class="cite ls__cite" aria-expanded="false" aria-controls="' + id + '">Source</button>' +
        '</span>' +
      '</div>' +
      '<div class="ls__panel cite-panel-wrap" id="' + id + '" role="region" aria-label="Citation details"><div class="cite-panel-inner"><div class="cite-panel">' +
        '<p class="cite-panel__where">' + esc(r.src) + ' · ' + (r.date || DATE) + '</p>' +
        '<blockquote>"' + esc(r.ex) + '"</blockquote>' +
        '<a href="' + esc(r.url) + '" target="_blank" rel="noopener noreferrer">View source at ' + esc(r.host) + '</a>' +
      '</div></div></div>';
  }

  KEYS.forEach(function (k) {
    var li = document.createElement('li');
    li.className = 'ls__row';
    li.setAttribute('data-k', k);
    rows[k] = li;
    listEl.appendChild(li);
  });

  function apply(key, animate) {
    var s = SCEN[key];
    nameEl.textContent = s.name;
    rankedByEl.textContent = s.rankedBy;

    var first = {};
    if (animate && !prefersReduced) {
      KEYS.forEach(function (k) { first[k] = rows[k].getBoundingClientRect().top; });
    }

    /* update content + reorder the persistent rows into ranked order */
    s.rows.forEach(function (r, i) {
      var li = rows[r.k];
      li.innerHTML = cellHTML(PLACES[r.k], i + 1, r);
      li.classList.toggle('is-top', i === 0);
      listEl.appendChild(li);
    });

    /* FLIP: invert to old position, then release to animate to the new one */
    if (animate && !prefersReduced) {
      KEYS.forEach(function (k) {
        var li = rows[k];
        var dy = first[k] - li.getBoundingClientRect().top;
        if (dy) { li.style.transition = 'none'; li.style.transform = 'translateY(' + dy + 'px)'; li.style.willChange = 'transform'; }
      });
      requestAnimationFrame(function () {
        KEYS.forEach(function (k) {
          var li = rows[k];
          li.style.transition = 'transform 520ms var(--ease)';
          li.style.transform = '';
          /* release the compositor layer once the slide settles */
          li.addEventListener('transitionend', function clr() { li.style.willChange = 'auto'; li.removeEventListener('transitionend', clr); }, { once: true });
        });
      });
    }
  }

  document.querySelectorAll('input[name="ls-scenario"]').forEach(function (radio) {
    radio.addEventListener('change', function () { if (radio.checked) apply(radio.value, true); });
  });
  var taxRadio = document.querySelector('input[name="ls-scenario"][value="tax"]');
  if (taxRadio) taxRadio.checked = true;

  /* citation expand (delegated; rows persist, panels reset closed on re-render) */
  listEl.addEventListener('click', function (e) {
    var btn = e.target.closest('.cite');
    if (!btn) return;
    var panel = document.getElementById(btn.getAttribute('aria-controls'));
    if (!panel) return;
    var exp = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!exp));
    panel.classList.toggle('open', !exp);
  });

  apply('tax', false);
}());
</script>

</body>
</html>
