---
import { placeById, qa, regimes, tools, topics } from "@where/data";
import FenceBlock from "../components/FenceBlock.astro";
import Base from "../layouts/Base.astro";
import { itemListJsonLd } from "../lib/jsonld";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/guides`;
const title = "Guides | My Second Country";
const description =
  "Cited answers, tax regime explainers, topic guides, and eligibility tools for building a relocation shortlist.";

const regimeCards = regimes.flatMap((regime) => {
  const country = placeById(regime.countryId);
  if (!country) return [];
  return [
    {
      href: `/${country.slug}/tax/${regime.slug}`,
      title: regime.name,
      copy: regime.summary,
      meta: country.name,
    },
  ];
});

const guideItems = [
  ...qa.map((entry) => ({ name: entry.question, url: `${SITE}/answers/${entry.slug}` })),
  ...regimeCards.map((entry) => ({ name: entry.title, url: `${SITE}${entry.href}` })),
  ...topics.map((topic) => ({ name: topic.title, url: `${SITE}/topics/${topic.slug}` })),
  ...tools.map((tool) => ({ name: tool.title, url: `${SITE}/tools/${tool.slug}` })),
];

const guideGroups = [
  {
    id: "shortlist-questions",
    kicker: "Task",
    title: "Answer a shortlist question",
    readiness: "Published answers",
    note:
      "Use these when a question can be answered without opening a full country or town dossier.",
    entries: qa.map((entry) => ({
      href: `/answers/${entry.slug}`,
      title: entry.question,
      copy: entry.answer,
      meta: entry.category,
    })),
  },
  {
    id: "tax-residency-checks",
    kicker: "Task",
    title: "Check a tax or residency route",
    readiness: "Published high-liability pages",
    note:
      "These entries carry provenance cues because tax, visa, and residency claims need source inspection.",
    entries: regimeCards.map((entry) => ({
      href: entry.href,
      title: entry.title,
      copy: entry.copy,
      meta: entry.meta,
    })),
  },
  {
    id: "explainers",
    kicker: "Task",
    title: "Understand the context behind a row",
    readiness: "Published explainers",
    note:
      "Use these when the comparison table is too compressed for the next reader question.",
    entries: topics.map((topic) => ({
      href: `/topics/${topic.slug}`,
      title: topic.title,
      copy: topic.metaDescription,
      meta: topic.countryId ? "Country context" : "General context",
    })),
  },
  {
    id: "checklists",
    kicker: "Task",
    title: "Work through a checklist",
    readiness: "Published tools",
    note:
      "Tools show which requirements are official claims and where each requirement comes from.",
    entries: tools.map((tool) => ({
      href: `/tools/${tool.slug}`,
      title: tool.title,
      copy: tool.intro,
      meta: tool.toolType,
    })),
  },
].filter((group) => group.entries.length > 0);

const jsonLd = [
  itemListJsonLd({
    url: canonical,
    items: guideItems.map((item, i) => ({
      position: i + 1,
      name: item.name,
      url: item.url,
    })),
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="corridor-page">
    <nav class="corridor-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Guides</span>
    </nav>

    <header class="corridor-hero">
      <p class="corridor-kicker">Guides</p>
      <h1 class="corridor-title">Evidence for the shortlist.</h1>
      <p class="corridor-lead">
        Start here when a rule, tax route, or checklist needs more context than a
        comparison row can carry. Every guide points back to the source record it uses.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    {
      guideGroups.map((group) => (
        <section class="corridor-section" aria-labelledby={group.id}>
          <div class="corridor-section-head">
            <div>
              <p class="corridor-kicker">{group.kicker}</p>
              <h2 id={group.id}>{group.title}</h2>
              <p class="corridor-readiness">{group.readiness}</p>
            </div>
            <p class="corridor-section-note">{group.note}</p>
          </div>
          <div class="corridor-grid">
            {group.entries.map((entry) => (
              <a class="corridor-card" href={entry.href}>
                <span class="corridor-card__meta">{entry.meta} / {group.readiness}</span>
                <div>
                  <h3 class="corridor-card__title">{entry.title}</h3>
                  <p class="corridor-card__copy">{entry.copy}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </article>

  <style>
    :global(.footer-top[data-reveal]) {
      opacity: 1 !important;
      visibility: visible !important;
    }

    @media (min-width: 861px) and (max-width: 940px) {
      :global(.site-header .nav-cta) {
        display: none;
      }
    }

    .corridor-readiness {
      margin: 0.45rem 0 0;
      color: var(--stone);
      font: 600 var(--t-meta) var(--f-mono);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</Base>
