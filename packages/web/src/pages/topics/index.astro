---
import { topics } from "@where/data";
import FenceBlock from "../../components/FenceBlock.astro";
import Base from "../../layouts/Base.astro";
import { itemListJsonLd } from "../../lib/jsonld";

const SITE = "https://mysecondcountry.com";
const canonical = `${SITE}/topics`;
const title = "Topics | My Second Country";
const description =
  "Sourced topic guides covering tax regimes, visa rules, and residency requirements in EU countries. Every figure is cited and dated.";

const jsonLd = [
  itemListJsonLd({
    url: canonical,
    items: topics.map((topic, i) => ({
      position: i + 1,
      name: topic.title,
      url: `${SITE}/topics/${topic.slug}`,
    })),
  }),
];
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article class="corridor-page">
    <nav class="corridor-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Topics</span>
    </nav>

    <header class="corridor-hero">
      <p class="corridor-kicker">Topics</p>
      <h1 class="corridor-title">Rule context for a careful reader.</h1>
      <p class="corridor-lead">
        Topic pages explain the parts of a relocation rule that need more room than a
        shortlist row or a comparison cell.
      </p>
    </header>

    <FenceBlock hasLegalClaims={true} />

    <section class="corridor-section" aria-labelledby="topic-files">
      <div class="corridor-section-head">
        <div>
          <p class="corridor-count">{topics.length} live</p>
          <h2 id="topic-files">Topic files</h2>
        </div>
        <p class="corridor-section-note">
          Each topic starts from cited facts and keeps the source trail visible.
        </p>
      </div>
      <div class="corridor-grid">
        {
          topics.map((topic) => (
            <a class="corridor-card" href={`/topics/${topic.slug}`}>
              <span class="corridor-card__meta">{topic.countryId ? "Country topic" : "General topic"}</span>
              <div>
                <h3 class="corridor-card__title">{topic.title}</h3>
                <p class="corridor-card__copy">{topic.metaDescription}</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </article>
</Base>
