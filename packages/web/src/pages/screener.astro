---
import FenceBlock from "../components/FenceBlock.astro";
import Base from "../layouts/Base.astro";

const SITE = "https://mysecondcountry.com";
const title = "Where should I live? A free, cited relocation screener";
const description =
  "Enter your budget, climate, visa, and tax constraints and get a cited, ranked shortlist of Greece, Portugal, and Spain. Every figure is sourced and dated. It shows how each country's published rules match what you entered; it never tells you what to do.";
const canonical = `${SITE}/screener`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "My Second Country relocation screener",
  applicationCategory: "Lifestyle",
  operatingSystem: "Web",
  url: canonical,
  isAccessibleForFree: true,
  offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
  description,
};
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <article data-page="screener">
    <p class="kicker">Free screener</p>
    <h1>Where should you live?</h1>

    <FenceBlock hasLegalClaims={true} />

    <p class="lede">{description}</p>

    <div class="screener">
      <form id="screener-form" aria-label="Screening constraints">
        <fieldset>
          <legend>Your constraints</legend>

          <div class="field">
            <label for="profile">Start as</label>
            <select id="profile" name="profile">
              <!-- Options populated by island script from PROFILES -->
            </select>
          </div>

          <div class="field">
            <label>
              <input type="checkbox" id="lgbtq" name="lgbtq" />
              Add LGBTQ+ overlay
            </label>
            <p class="hint">Nudges English proficiency and safety weighting. The acceptance/legal variable lands in a later slice.</p>
          </div>

          <div class="field">
            <label for="income">Provable net monthly income (EUR)</label>
            <input
              type="number"
              id="income"
              name="income"
              min="0"
              step="100"
              placeholder="e.g. 4000 (leave blank to skip the visa check)"
            />
            <p class="hint">Used only to compare against each country's published digital nomad visa income floor.</p>
          </div>

          <div id="filters"></div>
        </fieldset>
      </form>

      <section class="results" aria-live="polite" aria-label="Screening results">
        <div id="results"></div>
      </section>
    </div>

    <p class="method">
      How it works: you pick a profile, which surfaces the variables most relevant to your
      situation. Each country's published figures are matched against your constraints, then
      weighted by source confidence (a low-confidence figure counts for less). The score is the
      confidence-weighted share of your stated criteria that match. It is a screening signal, not
      a recommendation. Open any country's <a href="/compare/greece-portugal-spain">full cited
      comparison</a> to check every source yourself.
    </p>
  </article>

  <style>
    .kicker {
      font-size: 0.82rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--terracotta-dark);
      margin: 0 0 0.3rem;
    }
    .lede {
      max-width: var(--measure);
      font-size: 1.12rem;
      line-height: 1.55;
      color: var(--ink-soft);
      margin: 0 0 1.5rem;
    }
    .screener {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 46rem) {
      .screener {
        grid-template-columns: 1fr;
      }
    }
    fieldset {
      border: 1px solid var(--rule);
      border-radius: 8px;
      padding: 1.2rem 1.3rem 1.4rem;
      background: var(--paper-2);
    }
    legend {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 600;
      padding: 0 0.4rem;
    }
    .field {
      margin-top: 1rem;
    }
    .field label {
      display: block;
      font-weight: 600;
      margin-bottom: 0.3rem;
    }
    .field select {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border: 1px solid var(--rule);
      border-radius: 6px;
      font-size: 1rem;
      background: var(--paper);
    }
    .field input[type="number"] {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border: 1px solid var(--rule);
      border-radius: 6px;
      font-size: 1rem;
      background: var(--paper);
    }
    .field input[type="range"] {
      width: 100%;
      accent-color: var(--terracotta);
    }
    .field input[type="checkbox"] {
      margin-right: 0.4rem;
    }
    .field output {
      font-weight: 700;
      color: var(--terracotta-dark);
    }
    .hint {
      margin: 0.3rem 0 0;
      font-size: 0.85rem;
      color: var(--ink-soft);
    }
    .method {
      max-width: var(--measure);
      margin-top: 2.5rem;
      color: var(--ink-soft);
      font-size: 0.95rem;
    }
    /* Result cards are injected client-side via innerHTML, so they do not carry Astro's
       scoped style hash. These selectors must be :global to reach them. */
    :global(.rank-card) {
      border: 1px solid var(--rule);
      border-top: 3px solid var(--terracotta);
      border-radius: 8px;
      padding: 1.1rem 1.2rem;
      margin-bottom: 1rem;
      background: var(--paper);
    }
    :global(.rank-head) {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
    :global(.rank-name) {
      font-family: var(--serif);
      font-size: 1.45rem;
      font-weight: 600;
    }
    :global(.rank-name a) {
      color: var(--ink);
      text-decoration: none;
    }
    :global(.rank-score) {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--terracotta-dark);
    }
    :global(.rank-sub) {
      color: var(--ink-soft);
      font-size: 0.92rem;
      margin: 0.2rem 0 0.8rem;
    }
    :global(.rank-dims) {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.35rem;
    }
    :global(.rank-dims li) {
      display: flex;
      gap: 0.5rem;
      font-size: 0.92rem;
      line-height: 1.4;
    }
    :global(.rank-dims .mark) {
      flex: none;
      font-weight: 700;
      min-width: 3.2rem;
    }
    :global(.mark-yes) {
      color: #1f5132;
    }
    :global(.mark-no) {
      color: #7a1f1f;
    }
    :global(.warn) {
      margin-top: 0.7rem;
      font-size: 0.85rem;
      color: #7a1f1f;
    }
    :global(.mark-nodata) { color: var(--ink-soft); font-style: italic; }
    :global(.cbadge) { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.02em; padding: 0.05rem 0.4rem; border-radius: 999px;
      border: 1px solid var(--rule); margin-left: 0.4rem; }
    :global(.cbadge-high) { color: #1f5132; border-color: #9ec9ac; background: #eef6f0; }
    :global(.cbadge-medium) { color: #6b4a12; border-color: #d9c08a; background: #f8f1de; }
    :global(.cbadge-low) { color: #7a1f1f; border-color: #d9a3a3; background: #f8e9e9; }
    :global(.rank-src) { display: block; font-size: 0.8rem; color: var(--ink-soft); margin-top: 0.15rem; }
  </style>

  <script>
    import {
      places,
      PROFILES,
      LGBTQ_OVERLAY,
      composeProfile,
      variableByKey,
      placeVariables,
      type Profile,
    } from "@where/data";
    import { applyFilters, scoreByProfile, type ActiveFilter } from "@where/engine";

    const countries = places.filter((p) => p.granularity === "country");

    const form = document.getElementById("screener-form") as HTMLFormElement;
    const resultsEl = document.getElementById("results") as HTMLElement;
    const profileSelect = document.getElementById("profile") as HTMLSelectElement;
    const lgbtqCheckbox = document.getElementById("lgbtq") as HTMLInputElement;
    const incomeInput = document.getElementById("income") as HTMLInputElement;
    const filtersContainer = document.getElementById("filters") as HTMLDivElement;

    // Populate the profile selector
    for (const p of PROFILES) {
      const opt = document.createElement("option");
      opt.value = p.id;
      opt.textContent = p.label;
      if (p.id === "budgetRetiree") opt.selected = true;
      profileSelect.appendChild(opt);
    }

    const RANGE_CONFIG: Record<string, { min: number; max: number; step: number; def: number }> = {
      cost_price_level:    { min: 70,   max: 110,  step: 1,    def: 90 },
      top_income_tax_rate: { min: 0,    max: 60,   step: 1,    def: 46 },
      summer_high:         { min: 20,   max: 45,   step: 0.5,  def: 33 },
      gpi_score:           { min: 1,    max: 3.5,  step: 0.05, def: 1.7 },
      air_quality_pm25:    { min: 0,    max: 50,   step: 1,    def: 25 },
      winter_high:         { min: 0,    max: 25,   step: 0.5,  def: 12 },
      annual_sunshine:     { min: 1500, max: 3500, step: 25,   def: 2800 },
      physicians_per_1k:   { min: 0,    max: 8,    step: 0.1,  def: 5 },
      english_proficiency: { min: 0,    max: 700,  step: 10,   def: 500 },
      cafe_density:        { min: 0,    max: 500,  step: 10,   def: 100 },
      gym_density:         { min: 0,    max: 200,  step: 5,    def: 40 },
    };

    function esc(s: string): string {
      return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] ?? c);
    }

    function placeHref(p: (typeof countries)[number]): string {
      return `/places/${[...p.ancestry.map((a) => a.slug), p.slug].join("/")}`;
    }

    function getComposed(): ReturnType<typeof composeProfile> {
      const base = PROFILES.find((p) => p.id === profileSelect.value) ?? PROFILES[0];
      return composeProfile(base as Profile, lgbtqCheckbox.checked ? LGBTQ_OVERLAY : undefined);
    }

    function renderFilterControls(): void {
      const composed = getComposed();
      const html: string[] = [];

      for (const key of composed.surfaced) {
        const def = variableByKey(key);
        if (def === undefined) continue;

        if (key === "dnv_income_floor") {
          html.push(
            `<div class="field"><p class="hint">Digital nomad visa floor: uses your income above.</p></div>`,
          );
          continue;
        }

        if (def.filterType === "range") {
          const cfg = RANGE_CONFIG[key];
          if (cfg === undefined) continue;
          const outId = `out-${key}`;
          const unit = def.unit ? ` ${esc(def.unit)}` : "";
          html.push(`
            <div class="field">
              <label for="range-${esc(key)}">${esc(def.label)} <output id="${outId}">${cfg.def}</output>${unit}</label>
              <input type="range" id="range-${esc(key)}" data-vkey="${esc(key)}"
                min="${cfg.min}" max="${cfg.max}" step="${cfg.step}" value="${cfg.def}" />
              <p class="hint">${unit.trim() ? `Unit: ${esc(def.unit ?? "")}. ` : ""}Source: ${esc(def.source.name)}</p>
            </div>`);
          continue;
        }

        if (def.filterType === "boolean") {
          html.push(`
            <div class="field">
              <label><input type="checkbox" data-vkey="${esc(key)}" /> ${esc(def.label)}</label>
              <p class="hint">Check to require this is available. Source: ${esc(def.source.name)}</p>
            </div>`);
          continue;
        }

        // filterType === "select" or range key missing RANGE_CONFIG: skip gracefully
      }

      filtersContainer.innerHTML = html.join("");

      // Wire up live output labels for the newly rendered sliders
      for (const input of filtersContainer.querySelectorAll<HTMLInputElement>("input[type='range']")) {
        const key = input.dataset.vkey;
        if (key === undefined) continue;
        const out = document.getElementById(`out-${key}`);
        if (out === null) continue;
        const sync = () => { out.textContent = input.value; };
        input.addEventListener("input", sync);
        sync();
      }
    }

    function render(): void {
      const composed = getComposed();
      const incomeRaw = incomeInput.value === "" ? undefined : Number(incomeInput.value);
      const income = incomeRaw !== undefined && Number.isFinite(incomeRaw) && incomeRaw > 0 ? incomeRaw : undefined;

      // Build criteria from surfaced range sliders
      const criteria: Record<string, { min?: number; max?: number }> = {};
      for (const input of filtersContainer.querySelectorAll<HTMLInputElement>("input[type='range'][data-vkey]")) {
        const key = input.dataset.vkey;
        if (key === undefined) continue;
        const v = Number(input.value);
        if (!Number.isFinite(v)) continue;
        const def = variableByKey(key);
        if (def === undefined) continue;
        if (def.direction === "higherBetter") {
          criteria[key] = { min: v };
        } else if (def.direction === "lowerBetter") {
          criteria[key] = { max: v };
        }
        // neutral: no criterion set
      }

      // dnv_income_floor: driven by income input
      if (composed.surfaced.includes("dnv_income_floor") && income !== undefined) {
        criteria.dnv_income_floor = { max: income };
      }

      // Build activeFilters from dealBreakers + checked boolean controls
      const activeFilters: ActiveFilter[] = [];

      for (const db of composed.dealBreakers) {
        if (db.op === "<=") {
          activeFilters.push({ key: db.key, max: db.value as number });
        } else if (db.op === ">=") {
          activeFilters.push({ key: db.key, min: db.value as number });
        } else if (db.op === "==") {
          activeFilters.push({ key: db.key, equals: db.value as string | boolean });
        }
        // "in": skip in slice 1
      }

      for (const input of filtersContainer.querySelectorAll<HTMLInputElement>("input[type='checkbox'][data-vkey]")) {
        if (input.checked) {
          activeFilters.push({ key: input.dataset.vkey as string, requireData: true });
        }
      }

      const survivors = applyFilters(countries, activeFilters);
      const ranked = survivors
        .map((place) => ({ place, result: scoreByProfile(place, composed, criteria) }))
        .sort((a, b) => b.result.score - a.result.score);

      resultsEl.innerHTML = ranked
        .map(({ place, result }, i) => {
          const vars = placeVariables(place);
          let matchCount = 0;
          let usedCount = 0;

          const dimRows = composed.surfaced.map((key) => {
            const def = variableByKey(key);
            const label = def ? esc(def.label) : esc(key);
            const cited = vars[key];

            if (cited === undefined || cited.value === undefined) {
              return `<li><span class="mark mark-nodata">no data</span><span>${label}: not gathered for this place yet.</span></li>`;
            }

            usedCount += 1;
            const criterion = criteria[key];
            const direction = def ? def.direction : "neutral";
            let match = true;
            if (criterion !== undefined && direction !== "neutral" && typeof cited.value === "number") {
              match =
                (criterion.min === undefined || cited.value >= criterion.min) &&
                (criterion.max === undefined || cited.value <= criterion.max);
            }
            if (match) matchCount += 1;

            const markClass = match ? "mark-yes" : "mark-no";
            const markText = match ? "match" : "no";
            const unit = def?.unit ? esc(def.unit) : "";
            const valueStr = esc(String(cited.value));

            let boundNote = "";
            if (criterion !== undefined) {
              if (criterion.min !== undefined) boundNote = ` (your min: ${criterion.min}${unit ? " " + unit : ""})`;
              else if (criterion.max !== undefined) boundNote = ` (your max: ${criterion.max}${unit ? " " + unit : ""})`;
            }

            const confidenceIcon = cited.confidence === "high" ? "●" : cited.confidence === "medium" ? "◐" : "○";
            const confidenceText = cited.confidence === "high" ? "verified source" : cited.confidence === "medium" ? "good source" : "low confidence, verify";
            const badge = `<span class="cbadge cbadge-${esc(cited.confidence)}">${confidenceIcon} ${confidenceText}</span>`;
            const srcLink = `<a href="${esc(cited.sourceUrl)}" rel="noopener nofollow" target="_blank">${esc(cited.sourceName)}</a>`;
            const srcLine = `<span class="rank-src">${srcLink} Verified ${esc(cited.verifiedDate)}${badge}</span>`;

            return `<li><span class="mark ${markClass}">${markText}</span><span>${label}: ${valueStr}${unit ? " " + unit : ""}${boundNote}${srcLine}</span></li>`;
          });

          const sub = `Matches ${matchCount} of ${usedCount} of your stated criteria. Score is the confidence-weighted share. Not a recommendation.`;

          return `
            <div class="rank-card">
              <div class="rank-head">
                <span class="rank-name">#${i + 1} <a href="${placeHref(place)}">${esc(place.name)}</a></span>
                <span class="rank-score">${result.score}</span>
              </div>
              <p class="rank-sub">${esc(sub)}</p>
              <ul class="rank-dims">${dimRows.join("")}</ul>
            </div>`;
        })
        .join("");

      const w = window as unknown as { plausible?: (e: string, o?: { props?: Record<string, unknown> }) => void };
      w.plausible?.("Screener Run", {
        props: { profile: profileSelect.value, top: ranked[0]?.place.id ?? "none" },
      });
    }

    function onProfileChange(): void {
      renderFilterControls();
      render();
    }

    profileSelect.addEventListener("change", onProfileChange);
    lgbtqCheckbox.addEventListener("change", onProfileChange);

    let t: ReturnType<typeof setTimeout> | undefined;
    form.addEventListener("input", (e) => {
      const target = e.target as HTMLElement;
      // Profile/lgbtq changes are handled by their own listeners (re-render controls)
      // Other inputs just re-run render
      if (target.id !== "profile" && target.id !== "lgbtq") {
        window.clearTimeout(t);
        t = setTimeout(render, 250);
      }
    });

    // Initial render
    onProfileChange();
  </script>
</Base>
